---
import Layout from "../layouts/Layout.astro";

const baseUrl = (import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
const asset = (path) => `${baseUrl}/${path.replace(/^\/+/ , "")}`;

const stats = [
	{ label: "Milchkühe", value: "≈ 70" },
	{ label: "Landwirtschaft", value: "100 ha" },
	{ label: "Forst", value: "12 ha" },
	{ label: "Ausbildung", value: "Start 1. August" }
];

const cornerstones = [
	{
		title: "Milchvieh",
		description: "Ruhige Herde, Laufstall, viel Handarbeit und Sensoren, die uns unterstützen.",
		bullets: ["Melken früh & abends", "Eigenes Futter", "Tierwohl zuerst"]
	},
	{
		title: "Felder & Maschinen",
		description: "Grünlandpflege, Getreide, Mais und Nachbarschaftshilfe – Technik aus Oberbubach.",
		bullets: ["Fendt, Claas, Pöttinger", "Bodenschonende Bearbeitung", "Helfen wenn wer Hilfe braucht"]
	}
];

const equipment = [
	{
		title: "Zugmaschinen",
		details: ["Fendt (300er & 500er Reihe)", "Telelader für Hofarbeiten", "Breitreifen für bodenschonenden Silageeinsatz"]
	},
	{
		title: "Ernte & Pflege",
		details: ["Pöttinger Schwader", "Neue Gaspardo Drillkombination", "Ballen- & Transporttechnik"]
	},
	{
		title: "Dienstleistungen",
		details: ["Grünlandpflege & Bodenbearbeitung", "Mais-/Getreideernte", "Nachbarschaftshilfe nach Absprache"]
	}
];

const trainingSlots = [
	{ year: "2026", status: "belegt", note: "Platz vergeben" },
	{ year: "2027", status: "belegt", note: "Platz vergeben" },
	{ year: "2028", status: "belegt", note: "Platz vergeben" },
	{ year: "2029", status: "frei", note: "Frei ab 01.08.2029" }
];

const gallery = [
	{ title: "Sommer über Oberbubach", image: asset("images/hof-panorama-sommer.webp") },
	{ title: "Winterruhe", image: asset("images/hof-panorama-winter.webp") },
	{ title: "Blick Richtung Silo", image: asset("images/hof-sicht-silo.webp") },
	{ title: "Schwadern am Abend", image: asset("images/schwadern.webp") },
	{ title: "Fendt beim Grubbern", image: asset("images/fendt-grubern.webp") },
	{ title: "Mähdrescher in Aktion", image: asset("images/mähdrescher.webp") }
];

const seasons = [
	{
		title: "Frühjahr",
		timeframe: "März – Mai",
		tasks: ["Böden lockern & nachsäen", "Sensoren & Stalltechnik warten", "Jungvieh auf die Weiden vorbereiten"]
	},
	{
		title: "Sommer",
		timeframe: "Juni – August",
		tasks: ["Grünlandpflege & Heu einbringen", "Maisbestand kontrollieren", "Nachbarschaftshilfe mit Maschinen"]
	},
	{
		title: "Herbst",
		timeframe: "September – November",
		tasks: ["Mais- und Getreideernte", "Silagen anlegen", "Felder für den Winter vorbereiten"]
	},
	{
		title: "Winter",
		timeframe: "Dezember – Februar",
		tasks: ["Ruhe im Stall & Kälberbetreuung", "Maschinenservice", "Planung fürs nächste Ausbildungsjahr"]
	}
];

const posts = [
	{
		title: "Hofchronik 2025 – was sich alles getan hat",
		date: "12. Februar 2026",
		category: "Hofleben",
		readTime: "4 Min.",
		status: "Entwurf in Bearbeitung",
		summary: "Neue Silos, mehr Sensoren im Stall und warum wir auf Heu aus eigener Ernte setzen.",
		link: "#chronik"
	},
	{
		title: "Ausbildungsplätze: 2026 vergeben, 2027 Warteliste",
		date: "28. Januar 2026",
		category: "Ausbildung",
		readTime: "3 Min.",
		status: "Veröffentlicht",
		summary: "Ein Blick hinter die Kulissen des Auswahlprozesses und was Bewerber erwarten können.",
		link: "#ausbildung-blog"
	},
	{
		title: "Neue Technik für die Felder",
		date: "05. Dezember 2025",
		category: "Maschinen",
		readTime: "2 Min.",
		status: "Live",
		summary: "Warum der neue Schwader & die Drillkombi unseren Alltag erleichtern.",
		link: "#maschinen-blog"
	}
];

const faqs = [
	{
		question: "Wie melde ich meinen Besuch an?",
		answer: "Kurz anrufen oder eine Mail schicken – wir sprechen einen Termin ab und sorgen dafür, dass jemand Zeit hat."
	},
	{
		question: "Wie läuft die Ausbildung?",
		answer: "Start immer 1. August. Wir nehmen 1-2 Personen, Wohnmöglichkeit nach Absprache. Melde dich frühzeitig."
	},
	{
		question: "Darf ich spontan vorbeikommen?",
		answer: "Bitte vorher anklingeln – dann nehmen wir uns Zeit und du stehst niemandem im Weg."
	}
];

const visit = {
	address: "Oberbubach · 94439 Roßbach",
	googleMaps: "https://maps.google.com/maps?q=Oberbubach%2C%2094439%20Ro%C3%9Fbach&output=embed",
	mapsLink: "https://maps.app.goo.gl/4ouS1fks4bA7Rh1s5"
};

const statsEmojis = ["🐄", "🌾", "🌲", "🎓"];
---
<Layout
	title="Göttl Hof – Oberbubach/ Roßbach"
	description="Familienbetrieb in Oberbubach (Roßbach): Milchvieh, Felder, Ausbildung und Nachbarschaftshilfe nach Absprache."
>
	<!-- ===== STICKY NAVIGATION ===== -->
	<nav class="site-nav" aria-label="Hauptnavigation">
		<div class="nav__inner">
			<a class="nav__brand" href="#hof-top" aria-label="Göttl Hof – zurück zum Seitenanfang">
				<svg class="nav__brand-icon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/></svg>
				<span class="nav__brand-name">Göttl Hof</span>
			</a>

			<!-- Checkbox Trick für Hamburger-Menü -->
			<input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" />
			<label for="nav-toggle" class="nav-hamburger" aria-label="Navigation öffnen/schließen">
				<span class="nav-hamburger__bar"></span>
				<span class="nav-hamburger__bar"></span>
				<span class="nav-hamburger__bar"></span>
			</label>

			<ul class="nav__links" role="list">
				<li><a href="#hof" class="nav__link">Hof</a></li>
				<li><a href="#maschinen" class="nav__link">Maschinen</a></li>
				<li><a href="#ausbildung" class="nav__link">Ausbildung</a></li>
				<li><a href="#anfahrt" class="nav__link">Anfahrt</a></li>
				<li><a href="#contact" class="nav__link nav__link--cta">Kontakt</a></li>
			</ul>
		</div>
	</nav>

	<main class="page" id="hof-top">

		<!-- ===== HERO ===== -->
		<section class="hero" aria-labelledby="hero-heading">
			<div class="hero__photo">
				<img
					src={asset("images/hof-panorama-sicht2-januar.webp")}
					alt="Göttl Hof im Winter – Panoramablick über Oberbubach"
					width="1200"
					height="800"
					fetchpriority="high"
				/>
			</div>
			<div class="hero__text">
				<p class="eyebrow">Oberbubach · Gemeinde Roßbach (Niederbayern)</p>
				<h1 id="hero-heading">Göttl Hof – Milch, Felder &amp; Ausbildung aus einer Hand</h1>
				<p class="hero__lead">
					Wir arbeiten hier als Familie, bilden jedes Jahr aus und helfen Nachbarn mit Technik und Erfahrung.
					Kein Shop, kein ChiChi – einfach anrufen oder schreiben.
				</p>
				<div class="hero__actions">
					<a class="btn btn--primary" href="#contact">Kontakt aufnehmen</a>
					<a class="link" href="#ausbildung">Ausbildung ab 1. August →</a>
				</div>
				<div class="hero__note">
					<p>Besuche und Gespräche bitte kurz vorher ankündigen – dann nehmen wir uns Zeit für euch.</p>
				</div>
			</div>
		</section>

		<!-- ===== STATS ===== -->
		<section class="stats" aria-label="Hofkennzahlen">
			{stats.map((item, i) => (
				<div class="stats__card">
					<span class="stats__emoji" aria-hidden="true">{statsEmojis[i]}</span>
					<p class="stats__value">{item.value}</p>
					<p class="stats__label">{item.label}</p>
				</div>
			))}
		</section>

		<!-- ===== HOF / CORNERSTONES ===== -->
		<section class="cornerstones" id="hof" aria-labelledby="cornerstones-heading">
			<div class="cornerstones__text">
				<h2 id="cornerstones-heading">Was unseren Hof ausmacht</h2>
				<p>
					Wir stehen morgens mit den Kühen auf, helfen Nachbarn mit Maschinen, führen Buch über Felder und geben
					Erfahrung weiter. Wer uns besuchen will, soll ein Gefühl bekommen, wie wir ticken: ruhig, ehrlich und
					bodenständig.
				</p>
			</div>
			<div class="cornerstones__cards">
				{cornerstones.map((block) => (
					<article class="card card--lift">
						<h3>{block.title}</h3>
						<p>{block.description}</p>
						<ul>
							{block.bullets.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<!-- ===== EQUIPMENT / MASCHINEN ===== -->
		<section class="equipment" id="maschinen" aria-labelledby="equipment-heading">
			<div class="section-header">
				<h2 id="equipment-heading">Maschinen &amp; Leistungen</h2>
				<p>
					Moderne Technik hilft uns, zuverlässig zu liefern – auf den eigenen Flächen wie auch bei Nachbarn. Alles
					nach Absprache und so, dass es zu Hof und Boden passt.
				</p>
			</div>
			<div class="equipment__grid">
				{equipment.map((card) => (
					<article class="card card--lift">
						<h3>{card.title}</h3>
						<ul>
							{card.details.map((detail) => (
								<li>{detail}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<!-- ===== GALLERY ===== -->
		<section class="gallery" aria-label="Hof Impressionen">
			{gallery.map((shot) => (
				<figure class="gallery__item">
					<img
						src={shot.image}
						alt={shot.title}
						loading="lazy"
						width="480"
						height="360"
					/>
					<figcaption>{shot.title}</figcaption>
				</figure>
			))}
		</section>

		<!-- ===== SEASONS ===== -->
		<section class="seasons" aria-labelledby="seasons-heading">
			<div class="seasons__intro">
				<h2 id="seasons-heading">Unser Jahr am Hof</h2>
				<p>Was wann passiert? Ein schneller Überblick über Feldarbeit, Stall und Zeiten, in denen wir besonders gut erreichbar sind.</p>
			</div>
			<div class="seasons__grid">
				{seasons.map((season) => (
					<article class="card card--lift">
						<p class="seasons__timeframe">{season.timeframe}</p>
						<h3>{season.title}</h3>
						<ul>
							{season.tasks.map((task) => (
								<li>{task}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<!-- ===== TRAINING / AUSBILDUNG ===== -->
		<section class="training" id="ausbildung" aria-labelledby="training-heading">
			<div class="training__info">
				<h2 id="training-heading">Ausbildung &amp; Mitarbeit</h2>
				<p>
					Start ist jedes Jahr am <strong>1. August</strong>. Wir nehmen 1–2 Personen, die Landwirtschaft wirklich
					lernen wollen. Eigene Projekte, Umgang mit Tieren und Maschinen, wohnen nach Absprache. Aktuell sind alle
					Plätze bis 2028 vergeben – frei wird es wieder ab 01.08.2029.
				</p>
				<div class="training__slots" aria-label="Ausbildungsplätze">
					{trainingSlots.map((slot) => (
						<div
							class={`training__slot ${slot.status === "frei" ? "training__slot--free" : "training__slot--booked"}`}
						>
							<div>
								<p class="training__slot-year">{slot.year}</p>
								<p class="training__slot-note">{slot.note}</p>
							</div>
							<span class="training__slot-badge" aria-label={slot.status === "frei" ? "frei" : "belegt"}>
								{slot.status === "frei" ? "frei" : "belegt"}
							</span>
						</div>
					))}
				</div>
			</div>
			<div class="training__cta">
				<img
					src={asset("images/kuh-mit-kalb.jpg")}
					alt="Kuh mit Kalb im Stall"
					loading="lazy"
					width="480"
					height="320"
					class="training__cta-image"
				/>
				<p>Sprich uns an, erzähl kurz wer du bist – wir melden uns fix.</p>
				<a class="btn btn--primary" href="#contact">Ausbildung anfragen</a>
			</div>
		</section>

		<!-- ===== FAQ ===== -->
		<section class="faq" aria-labelledby="faq-heading">
			<h2 id="faq-heading">Fragen, die wir oft hören</h2>
			<div class="faq__list">
				{faqs.map((item) => (
					<details class="faq__item">
						<summary class="faq__question">
							<span>{item.question}</span>
							<span class="faq__chevron" aria-hidden="true">▾</span>
						</summary>
						<p class="faq__answer">{item.answer}</p>
					</details>
				))}
			</div>
		</section>

		<!-- ===== VISIT / ANFAHRT ===== -->
		<section class="visit" id="anfahrt" aria-labelledby="visit-heading">
			<div class="visit__info">
				<h2 id="visit-heading">Anfahrt &amp; Besuch</h2>
				<p>
					Wir liegen direkt in <strong>{visit.address}</strong>. Melde dich kurz, bevor du losfährst – dann stellen wir
					sicher, dass jemand Zeit hat und Hof &amp; Tiere bereit sind.
				</p>
				<ul>
					<li>Besuche bitte vorher anmelden</li>
					<li>Parken am Hof – bitte langsam anfahren</li>
					<li>Navigation: „Göttl Hof Oberbubach"</li>
				</ul>
				<div class="visit__actions">
					<a class="btn btn--primary" href={visit.mapsLink} target="_blank" rel="noreferrer">Google Maps Route</a>
					<a class="btn btn--outline" href="https://www.komoot.com/de-de/highlight/3033657" target="_blank" rel="noreferrer">Komoot-Highlight</a>
				</div>
			</div>
			<div class="visit__map">
				<iframe
					src={visit.googleMaps}
					loading="lazy"
					title="Karte Oberbubach"
					allowfullscreen
					width="600"
					height="400"
				></iframe>
			</div>
		</section>

		<!-- ===== BLOG ===== -->
		<section class="blog" id="blog" aria-labelledby="blog-heading">
			<h2 id="blog-heading">Blog &amp; Aktuelles</h2>
			<div class="blog__cards">
				{posts.map((post) => (
					<article class="card card--lift">
						<p class="blog__badge">{post.category}</p>
						<h3>{post.title}</h3>
						<p class="blog__meta">
							<time datetime={post.date}>{post.date}</time> · {post.readTime}
						</p>
						<p>{post.summary}</p>
						<p class="blog__status">Status: {post.status}</p>
						<a class="btn btn--outline" href={post.link}>Mehr lesen</a>
					</article>
				))}
			</div>
		</section>

		<!-- ===== CONTACT ===== -->
		<section class="contact" id="contact" aria-labelledby="contact-heading">
			<div class="contact__inner">
				<h2 id="contact-heading">Kontakt &amp; Rückfragen</h2>
				<p>Wir freuen uns über eure Nachricht – am besten erreichbar täglich zwischen 18 und 20 Uhr.</p>
				<div class="contact__buttons">
					<a class="btn btn--primary" href="tel:+4985641268">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 15.92z"/></svg>
						Anrufen
					</a>
					<a class="btn btn--outline contact__btn-light" href="mailto:info@goettl-oberbubach.de">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
						Mail schreiben
					</a>
					<a class="btn btn--wa" href="https://wa.me/491605925821" target="_blank" rel="noreferrer">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
						WhatsApp
					</a>
				</div>
			</div>
		</section>

	</main>

	<footer class="site-footer">
		<p>© {new Date().getFullYear()} Göttl Hof · Oberbubach · 94439 Roßbach</p>
		<nav aria-label="Footer-Navigation">
			<a href="/impressum">Impressum</a>
		</nav>
	</footer>
</Layout>

<style>
/* ============================================================
   GLOBAL / RESET
   ============================================================ */
:global(html) {
	scroll-behavior: smooth;
}

@media (prefers-reduced-motion: reduce) {
	:global(html) {
		scroll-behavior: auto;
	}
	:global(*),
	:global(*::before),
	:global(*::after) {
		animation-duration: 0.01ms !important;
		animation-iteration-count: 1 !important;
		transition-duration: 0.01ms !important;
	}
}

:global(body) {
	margin: 0;
	background: var(--bg);
	color: var(--text);
	font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	transition: background 0.3s, color 0.3s;
}

/* Reposition dark-mode toggle so it lives inside the nav bar visually */
:global(#darkToggle) {
	top: 0.6rem;
	right: 0.75rem;
	z-index: 1100;
}

/* ============================================================
   FOCUS VISIBLE – Keyboard Navigation
   ============================================================ */
:global(:focus-visible) {
	outline: 3px solid var(--accent-gold);
	outline-offset: 3px;
	border-radius: 4px;
}

/* ============================================================
   STICKY NAVIGATION
   ============================================================ */
.site-nav {
	position: sticky;
	top: 0;
	z-index: 1000;
	background: rgba(255, 255, 255, 0.85);
	background: color-mix(in srgb, var(--bg-card) 88%, transparent);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	border-bottom: 1px solid var(--border);
	box-shadow: 0 2px 12px var(--shadow);
}

.nav__inner {
	display: flex;
	align-items: center;
	gap: 1rem;
	max-width: 1280px;
	margin: 0 auto;
	padding: 0 1rem;
	height: 64px;
}

.nav__brand {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	text-decoration: none;
	color: var(--text);
	font-family: "Playfair Display", serif;
	font-size: 1.15rem;
	font-weight: 600;
	white-space: nowrap;
	flex-shrink: 0;
}

.nav__brand-emoji {
	font-size: 1.3rem;
}

/* Push links to the right */
.nav__links {
	display: flex;
	align-items: center;
	gap: 0.25rem;
	list-style: none;
	margin: 0 0 0 auto;
	padding: 0;
	/* Leave space for the fixed dark toggle on the right */
	padding-right: 3.5rem;
}

.nav__link {
	display: inline-flex;
	align-items: center;
	padding: 0.5rem 0.75rem;
	min-height: 44px;
	text-decoration: none;
	color: var(--text-muted);
	font-size: 0.9rem;
	font-weight: 500;
	border-radius: 8px;
	transition: color 0.2s, background 0.2s;
	white-space: nowrap;
}

.nav__link:hover {
	color: var(--text);
	background: var(--bg-soft);
}

.nav__link--cta {
	background: var(--accent);
	color: #fff !important;
	padding: 0.5rem 1rem;
	border-radius: 999px;
	font-weight: 600;
}

.nav__link--cta:hover {
	background: var(--accent-dark);
}

/* Hamburger toggle – hidden input */
.nav-toggle-input {
	display: none;
}

/* Hamburger label – hidden on desktop */
.nav-hamburger {
	display: none;
	flex-direction: column;
	justify-content: center;
	gap: 5px;
	cursor: pointer;
	padding: 0.5rem;
	margin-left: auto;
	min-width: 44px;
	min-height: 44px;
	align-items: center;
	border-radius: 8px;
	transition: background 0.2s;
}

.nav-hamburger:hover {
	background: var(--bg-soft);
}

.nav-hamburger__bar {
	display: block;
	width: 22px;
	height: 2px;
	background: var(--text);
	border-radius: 2px;
	transition: transform 0.3s, opacity 0.3s;
}

/* Hamburger animation when open */
.nav-toggle-input:checked ~ .nav-hamburger .nav-hamburger__bar:nth-child(1) {
	transform: translateY(7px) rotate(45deg);
}
.nav-toggle-input:checked ~ .nav-hamburger .nav-hamburger__bar:nth-child(2) {
	opacity: 0;
}
.nav-toggle-input:checked ~ .nav-hamburger .nav-hamburger__bar:nth-child(3) {
	transform: translateY(-7px) rotate(-45deg);
}

/* ============================================================
   PAGE WRAPPER
   ============================================================ */
.page {
	display: flex;
	flex-direction: column;
	gap: clamp(2.5rem, 5vw, 4.5rem);
	padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 3vw, 2rem);
	max-width: 1280px;
	margin: 0 auto;
}

/* Scroll margin for sticky nav */
.page section {
	scroll-margin-top: 80px;
}

/* Shared heading fonts */
.page h1,
.page h2,
.page h3 {
	font-family: "Playfair Display", serif;
}

/* ============================================================
   EYEBROW / LABELS
   ============================================================ */
.eyebrow {
	text-transform: uppercase;
	letter-spacing: 0.22em;
	font-size: 0.75rem;
	color: var(--accent);
	margin: 0 0 0.5rem;
}

/* ============================================================
   HERO SECTION
   ============================================================ */
.hero {
	display: flex;
	flex-direction: column;
	border-radius: 1.5rem;
	overflow: hidden;
	background: var(--bg-card);
	box-shadow: 0 15px 40px var(--shadow);
	animation: fadeInUp 0.7s ease both;
}

@keyframes fadeInUp {
	from {
		opacity: 0;
		transform: translateY(24px);
	}
	to {
		opacity: 1;
		transform: translateY(0);
	}
}

.hero__photo {
	width: 100%;
	min-height: 60vw;
	overflow: hidden;
	flex-shrink: 0;
}

.hero__photo img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
}

.hero__text {
	padding: clamp(1.5rem, 4vw, 2.5rem);
}

.hero__text h1 {
	font-size: clamp(1.8rem, 5vw, 3.2rem);
	line-height: 1.2;
	margin: 0.3rem 0 1rem;
}

.hero__lead {
	line-height: 1.7;
	color: var(--text-muted);
	max-width: 60ch;
}

.hero__actions {
	display: flex;
	flex-wrap: wrap;
	gap: 0.75rem;
	margin: 1.5rem 0 1rem;
}

.hero__note {
	background: var(--bg-strong);
	padding: 0.8rem 1rem;
	border-radius: 0.8rem;
	font-size: 0.9rem;
}

.hero__note p {
	margin: 0;
	color: var(--text-muted);
}

/* Desktop hero: side by side */
@media (min-width: 768px) {
	.hero {
		flex-direction: row;
		align-items: stretch;
	}

	.hero__photo {
		flex: 1 1 50%;
		min-height: 60vh;
	}

	.hero__text {
		flex: 1 1 50%;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
}

/* ============================================================
   SHARED BUTTON STYLES
   ============================================================ */
.btn {
	display: inline-flex;
	justify-content: center;
	align-items: center;
	gap: 0.4rem;
	border-radius: 999px;
	padding: 0.75rem 1.5rem;
	min-height: 44px;
	font-size: 0.95rem;
	font-weight: 600;
	text-decoration: none;
	border: 2px solid transparent;
	cursor: pointer;
	transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.15s, box-shadow 0.15s;
	white-space: nowrap;
}

.btn:hover {
	transform: translateY(-2px);
	box-shadow: 0 6px 18px var(--shadow);
}

.btn:active {
	transform: translateY(0);
}

.btn--primary {
	background: var(--accent-gold);
	color: #1c1a15;
	border-color: var(--accent-gold);
}

.btn--primary:hover {
	background: color-mix(in srgb, var(--accent-gold) 85%, #000);
}

.btn--outline {
	background: transparent;
	color: var(--accent-gold);
	border-color: var(--accent-gold);
}

.btn--outline:hover {
	background: var(--accent-gold);
	color: #1c1a15;
}

.btn--neutral {
	background: var(--bg-strong);
	color: var(--text);
	border-color: var(--border);
}

.btn--neutral:hover {
	background: var(--bg-soft);
}

.link {
	display: inline-flex;
	align-items: center;
	min-height: 44px;
	background: none;
	border: none;
	color: var(--accent-dark);
	font-weight: 600;
	cursor: pointer;
	text-decoration: none;
	padding: 0.5rem 0;
	transition: color 0.2s;
}

.link:hover {
	color: var(--accent);
}

/* ============================================================
   SHARED CARD STYLES
   ============================================================ */
.card {
	background: var(--bg-card);
	border-radius: 1.2rem;
	padding: 1.3rem;
	border: 1px solid var(--border);
}

.card--lift {
	transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.card--lift:hover {
	transform: translateY(-4px);
	box-shadow: 0 12px 30px var(--shadow);
}

/* ============================================================
   STATS SECTION
   ============================================================ */
.stats {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 0.75rem;
}

.stats__card {
	background: var(--bg-card);
	border-radius: 1.2rem;
	padding: 1.25rem 1rem;
	text-align: center;
	border: 1px solid var(--border);
	transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.stats__card:hover {
	transform: translateY(-4px);
	box-shadow: 0 10px 25px var(--shadow);
}

.stats__emoji {
	font-size: 2rem;
	display: block;
	margin-bottom: 0.4rem;
	line-height: 1;
}

.stats__value {
	margin: 0;
	font-size: clamp(1.1rem, 2.5vw, 1.4rem);
	font-weight: 700;
	color: var(--text);
}

.stats__label {
	margin: 0.25rem 0 0;
	font-size: 0.85rem;
	color: var(--text-muted);
}

@media (min-width: 480px) {
	.stats {
		grid-template-columns: repeat(4, 1fr);
	}
}

/* ============================================================
   CORNERSTONES / HOF SECTION
   ============================================================ */
.cornerstones {
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
}

.cornerstones__text h2 {
	font-size: clamp(1.6rem, 4vw, 2.4rem);
	margin: 0 0 0.75rem;
}

.cornerstones__text p {
	color: var(--text-muted);
	line-height: 1.7;
	max-width: 60ch;
}

.cornerstones__cards {
	display: grid;
	grid-template-columns: 1fr;
	gap: 1rem;
}

.cornerstones__cards ul {
	padding-left: 1.2rem;
	color: var(--text-muted);
	margin: 0.5rem 0 0;
}

@media (min-width: 768px) {
	.cornerstones {
		display: grid;
		grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
		align-items: start;
	}

	.cornerstones__cards {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}
}

/* ============================================================
   EQUIPMENT / MASCHINEN SECTION
   ============================================================ */
.equipment {
	background: var(--bg-card);
	border-radius: 1.5rem;
	padding: clamp(1.5rem, 3vw, 2.5rem);
	border: 1px solid var(--border);
	box-shadow: 0 10px 25px var(--shadow);
}

.section-header {
	margin-bottom: 1.5rem;
}

.section-header h2 {
	font-size: clamp(1.6rem, 4vw, 2.4rem);
	margin: 0 0 0.6rem;
}

.section-header p {
	color: var(--text-muted);
	line-height: 1.7;
	max-width: 65ch;
}

.equipment__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: 1rem;
}

.equipment__grid h3 {
	margin: 0 0 0.6rem;
	font-size: 1.1rem;
}

.equipment__grid ul {
	padding-left: 1.2rem;
	margin: 0;
	color: var(--text-muted);
}

@media (min-width: 480px) {
	.equipment__grid {
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
	}
}

/* ============================================================
   GALLERY SECTION
   ============================================================ */
.gallery {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 0.6rem;
}

.gallery__item {
	margin: 0;
	background: var(--bg-card);
	border-radius: 1rem;
	overflow: hidden;
	border: 1px solid var(--border);
	aspect-ratio: 4 / 3;
	position: relative;
}

.gallery__item img {
	width: 100%;
	height: 100%;
	object-fit: cover;
	display: block;
	transition: transform 0.4s ease;
}

.gallery__item:hover img {
	transform: scale(1.06);
}

.gallery__item figcaption {
	position: absolute;
	bottom: 0;
	left: 0;
	right: 0;
	padding: 0.6rem 0.8rem;
	font-size: 0.8rem;
	color: #fff;
	background: linear-gradient(transparent, rgba(0,0,0,0.6));
}

@media (min-width: 480px) {
	.gallery {
		grid-template-columns: repeat(3, 1fr);
	}
}

@media (min-width: 1024px) {
	.gallery {
		grid-template-columns: repeat(3, 1fr);
		gap: 0.8rem;
	}
}

/* ============================================================
   SEASONS SECTION
   ============================================================ */
.seasons {
	background: var(--bg-card);
	border-radius: 1.5rem;
	padding: clamp(1.5rem, 3vw, 2.5rem);
	border: 1px solid var(--border);
	box-shadow: 0 10px 25px var(--shadow);
}

.seasons__intro {
	margin-bottom: 1.5rem;
}

.seasons__intro h2 {
	font-size: clamp(1.6rem, 4vw, 2.4rem);
	margin: 0 0 0.5rem;
}

.seasons__intro p {
	color: var(--text-muted);
	line-height: 1.7;
	max-width: 60ch;
}

.seasons__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: 1rem;
}

.seasons__grid article {
	background: var(--bg-soft);
	border-radius: 1rem;
	padding: 1.2rem;
	border: 1px solid var(--border);
}

.seasons__timeframe {
	margin: 0;
	font-size: 0.8rem;
	letter-spacing: 0.06em;
	text-transform: uppercase;
	color: var(--accent);
	font-weight: 600;
}

.seasons__grid h3 {
	margin: 0.3rem 0 0.6rem;
	font-size: 1.1rem;
}

.seasons__grid ul {
	padding-left: 1.1rem;
	margin: 0;
	color: var(--text-muted);
}

@media (min-width: 480px) {
	.seasons__grid {
		grid-template-columns: repeat(2, 1fr);
	}
}

@media (min-width: 768px) {
	.seasons__grid {
		grid-template-columns: repeat(4, 1fr);
	}
}

/* ============================================================
   TRAINING / AUSBILDUNG SECTION
   ============================================================ */
.training {
	background: var(--bg-card);
	border-radius: 1.5rem;
	padding: clamp(1.5rem, 3vw, 2.5rem);
	border: 1px solid var(--border);
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
}

.training__info h2 {
	font-size: clamp(1.6rem, 4vw, 2.4rem);
	margin: 0 0 0.75rem;
}

.training__info p {
	color: var(--text-muted);
	line-height: 1.7;
}

.training__slots {
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
	margin-top: 1rem;
}

.training__slot {
	background: var(--bg-soft);
	border: 1px solid var(--border);
	border-radius: 1rem;
	padding: 0.9rem 1.2rem;
	display: flex;
	justify-content: space-between;
	align-items: center;
	gap: 1rem;
}

.training__slot-year {
	margin: 0;
	font-weight: 600;
	font-size: 1rem;
}

.training__slot-note {
	margin: 0.15rem 0 0;
	color: var(--text-muted);
	font-size: 0.88rem;
}

.training__slot-badge {
	text-transform: uppercase;
	font-size: 0.72rem;
	letter-spacing: 0.12em;
	padding: 0.35rem 0.85rem;
	border-radius: 999px;
	font-weight: 700;
	flex-shrink: 0;
}

.training__slot--booked .training__slot-badge {
	background: var(--bg-strong);
	color: var(--text-muted);
}

.training__slot--free .training__slot-badge {
	background: var(--accent-light);
	color: var(--accent-dark);
}

.training__cta {
	background: var(--bg-strong);
	padding: 1.5rem;
	border-radius: 1rem;
	display: flex;
	flex-direction: column;
	gap: 1rem;
}

.training__cta p {
	margin: 0;
	color: var(--text-muted);
}

.training__cta-image {
	width: 100%;
	border-radius: 0.9rem;
	object-fit: cover;
	border: 1px solid var(--border);
	aspect-ratio: 3 / 2;
}

@media (min-width: 768px) {
	.training {
		flex-direction: row;
		align-items: start;
	}

	.training__info {
		flex: 2;
	}

	.training__cta {
		flex: 1;
		flex-shrink: 0;
		min-width: 220px;
	}
}

/* ============================================================
   FAQ SECTION – details/summary Accordion
   ============================================================ */
.faq {
	background: var(--bg-card);
	border-radius: 1.5rem;
	padding: clamp(1.5rem, 3vw, 2.5rem);
	border: 1px solid var(--border);
}

.faq h2 {
	font-size: clamp(1.6rem, 4vw, 2.4rem);
	margin: 0 0 1.25rem;
}

.faq__list {
	display: flex;
	flex-direction: column;
	gap: 0.6rem;
}

.faq__item {
	background: var(--bg-soft);
	border-radius: 1rem;
	border: 1px solid var(--border);
	overflow: hidden;
}

.faq__item[open] {
	border-color: var(--accent);
}

.faq__question {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 1rem;
	padding: 1rem 1.2rem;
	cursor: pointer;
	font-weight: 600;
	font-size: 1rem;
	list-style: none;
	min-height: 44px;
	transition: background 0.2s;
}

.faq__question::-webkit-details-marker {
	display: none;
}

.faq__question:hover {
	background: var(--bg-strong);
}

.faq__chevron {
	flex-shrink: 0;
	font-size: 1.1rem;
	color: var(--accent);
	transition: transform 0.25s ease;
}

.faq__item[open] .faq__chevron {
	transform: rotate(180deg);
}

.faq__answer {
	margin: 0;
	padding: 0 1.2rem 1rem;
	color: var(--text-muted);
	line-height: 1.7;
}

/* ============================================================
   VISIT / ANFAHRT SECTION
   ============================================================ */
.visit {
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
	background: var(--bg-card);
	border-radius: 1.5rem;
	padding: clamp(1.5rem, 3vw, 2.5rem);
	border: 1px solid var(--border);
}

.visit__info h2 {
	font-size: clamp(1.6rem, 4vw, 2.4rem);
	margin: 0 0 0.75rem;
}

.visit__info p {
	color: var(--text-muted);
	line-height: 1.7;
}

.visit__info ul {
	padding-left: 1.2rem;
	color: var(--text-muted);
}

.visit__actions {
	display: flex;
	flex-wrap: wrap;
	gap: 0.6rem;
	margin-top: 1rem;
}

.visit__map iframe {
	width: 100%;
	border: none;
	height: 260px;
	border-radius: 1rem;
	display: block;
}

@media (min-width: 768px) {
	.visit {
		flex-direction: row;
		align-items: start;
	}

	.visit__info {
		flex: 1;
	}

	.visit__map {
		flex: 1;
	}

	.visit__map iframe {
		height: 320px;
	}
}

/* ============================================================
   BLOG SECTION
   ============================================================ */
.blog {
	padding: 0;
}

.blog h2 {
	font-size: clamp(1.6rem, 4vw, 2.4rem);
	margin: 0 0 1.25rem;
}

.blog__cards {
	display: grid;
	grid-template-columns: 1fr;
	gap: 1rem;
}

.blog__cards article {
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
}

.blog__badge {
	text-transform: uppercase;
	font-size: 0.72rem;
	letter-spacing: 0.14em;
	color: var(--accent);
	font-weight: 600;
	margin: 0;
}

.blog__cards h3 {
	margin: 0;
	font-size: 1.05rem;
}

.blog__meta {
	margin: 0;
	font-size: 0.85rem;
	color: var(--text-muted);
}

.blog__status {
	font-size: 0.82rem;
	color: var(--text-muted);
	margin: 0;
}

@media (min-width: 480px) {
	.blog__cards {
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
	}
}

/* ============================================================
   CONTACT SECTION – Green Accent Strip
   ============================================================ */
.contact {
	background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%);
	border-radius: 1.5rem;
	padding: clamp(2rem, 5vw, 3.5rem) clamp(1.5rem, 4vw, 3rem);
	text-align: center;
	box-shadow: 0 12px 32px rgba(0,0,0,0.18);
}

.contact__inner {
	max-width: 560px;
	margin: 0 auto;
}

.contact h2 {
	font-size: clamp(1.6rem, 4vw, 2.4rem);
	margin: 0 0 0.75rem;
	color: #fff;
}

.contact p {
	color: rgba(255,255,255,0.85);
	line-height: 1.7;
	margin-bottom: 1.75rem;
}

.contact__buttons {
	display: flex;
	flex-direction: column;
	gap: 0.75rem;
	align-items: center;
}

/* Light variants for buttons on dark/green background */
.contact .btn--primary {
	background: #fff;
	color: var(--accent-dark);
	border-color: #fff;
}

.contact .btn--primary:hover {
	background: rgba(255,255,255,0.9);
}

.contact__btn-light {
	border-color: rgba(255,255,255,0.7) !important;
	color: #fff !important;
}

.contact__btn-light:hover {
	background: rgba(255,255,255,0.15) !important;
	color: #fff !important;
}

.contact .btn--neutral {
	background: rgba(255,255,255,0.15);
	color: #fff;
	border-color: rgba(255,255,255,0.4);
}

.contact .btn--neutral:hover {
	background: rgba(255,255,255,0.25);
}

/* Side by side on larger screens */
@media (min-width: 480px) {
	.contact__buttons {
		flex-direction: row;
		justify-content: center;
		flex-wrap: wrap;
	}
}

/* ============================================================
   MOBILE NAVIGATION
   ============================================================ */
@media (max-width: 767px) {
	.nav__links {
		/* Hidden by default on mobile */
		position: fixed;
		top: 64px;
		left: 0;
		right: 0;
		background: var(--bg-card);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		flex-direction: column;
		padding: 1rem;
		gap: 0.25rem;
		margin: 0;
		padding-right: 1rem; /* reset desktop override */
		/* Animate in/out */
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		pointer-events: none;
		transition: max-height 0.3s ease, opacity 0.25s ease;
	}

	.nav-toggle-input:checked ~ .nav__links {
		max-height: 400px;
		opacity: 1;
		pointer-events: auto;
	}

	.nav-hamburger {
		display: flex;
		/* Push to right but leave space for dark toggle */
		margin-left: auto;
		margin-right: 3rem;
	}

	.nav__link {
		width: 100%;
		padding: 0.75rem 1rem;
		font-size: 1rem;
		border-radius: 10px;
	}

	.nav__link--cta {
		margin-top: 0.5rem;
		justify-content: center;
	}
}

	/* ---- Icons ---- */
	.nav__brand-icon {
		width: 22px;
		height: 22px;
		vertical-align: middle;
		filter: invert(35%) sepia(50%) saturate(500%) hue-rotate(90deg);
	}

	:global(html.dark) .nav__brand-icon {
		filter: invert(70%) sepia(30%) saturate(400%) hue-rotate(90deg);
	}

	.stats__icon {
		width: 32px;
		height: 32px;
		margin-bottom: 0.25rem;
		filter: invert(35%) sepia(50%) saturate(500%) hue-rotate(90deg);
	}

	.btn__icon {
		width: 18px;
		height: 18px;
		vertical-align: middle;
		flex-shrink: 0;
	}

	/* phone/mail icons follow button text color */
	.btn--primary .btn__icon,
	.btn--outline .btn__icon,
	.btn--neutral .btn__icon {
		filter: none;
	}

	/* ---- Footer ---- */
	.site-footer {
		display: flex;
		flex-wrap: wrap;
		justify-content: space-between;
