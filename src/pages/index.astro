---
import Layout from "../layouts/Layout.astro";

const stats = [
	{ label: "Milchkühe", value: "≈ 120" },
	{ label: "Familienbetrieb", value: "seit 1978" },
	{ label: "Hektar", value: "85 ha" },
	{ label: "Generation", value: "3" }
];

const pillars = [
	{
		title: "Milch mit Herkunft",
		description:
			"Frische Rohmilch direkt vom Hof – nachvollziehbar, artgerecht und täglich kontrolliert.",
		icon: "🐄"
	},
	{
		title: "Boden & Felder",
		description: "Grünland, Getreide und Mais aus Niederbayern – wir arbeiten bodenschonend und klimabewusst.",
		icon: "🌾"
	},
	{
		title: "Familie & Gemeinschaft",
		description: "Drei Generationen, Nachbarschaftshilfe und eine Hofgemeinschaft, die zusammenhält.",
		icon: "🤝"
	}
];

const timeline = [
	{ time: "05:00", title: "Melkstand", text: "Sensorik, Handarbeit, ruhige Tiere." },
	{ time: "08:30", title: "Feld & Futter", text: "Grünlandpflege, Futterkreislauf, Maschinencheck." },
	{ time: "13:00", title: "Direktverkauf", text: "Milch & Eier vorbereiten, Bestellungen abstimmen." },
	{ time: "18:00", title: "Abendrunde", text: "Stallruhe, Technik checken, Familie am Tisch." }
];

const gallery = [
	{
		title: "Morgennebel über dem Stall",
		image: "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1600&q=80"
	},
	{
		title: "Felder bei Dämmerung",
		image: "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?auto=format&fit=crop&w=1600&q=80"
	},
	{
		title: "Familienmomente",
		image: "https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?auto=format&fit=crop&w=1600&q=80"
	}
];

const posts = [
	{
		title: "Frische Saison – wir starten durch",
		date: "März 2026",
		summary: "Neue Futterchargen, Maschinen gewartet, Felder bereit.",
		readingTime: "3 Min"
	},
	{
		title: "Milch direkt ab Hof",
		date: "Februar 2026",
		summary: "Warum echte Rohmilch so besonders ist – und wie du sie bei uns bekommst.",
		readingTime: "4 Min"
	},
	{
		title: "Ausbildung auf dem Hof",
		date: "Januar 2026",
		summary: "Wir suchen junge Menschen, die Landwirtschaft leben wollen.",
		readingTime: "5 Min"
	}
];

const farmGoods = [
	{
		title: "Milch ab Hof",
		detail: "Täglich ab 18 Uhr, bitte eigene Gefäße mitbringen.",
		note: "Vorbestellung per Telefon oder Mail spart Wartezeit."
	},
	{
		title: "Eier von glücklichen Hühnern",
		detail: "Limitierte Mengen – Abholung am Freitag & Samstag.",
		note: "Schreib uns kurz, dann legen wir für dich zurück."
	}
];

const jobOffer = {
	title: "Ausbildung & Mitarbeit",
	intro:
		"Wir bilden Landwirt:innen aus und bieten Einstiegsplätze für Menschen, die Landwirtschaft anpacken wollen.",
	bullets: [
		"Praxis nah an Tier & Technik",
		"Eigenes Projekt je Saison",
		"Unterkunft/Verpflegung nach Absprache"
	]
};
---
<Layout
	title="Göttl Hof – Milchvieh, Felder, Familie"
	description="Moderner Familienhof in Niederbayern: Milch, Eier & Ausbildung direkt von der Familie Göttl."
>
	<main class="page">
		<section class="hero">
			<div class="hero__overlay"></div>
			<div class="hero__inner">
				<p class="eyebrow">Niederbayerischer Familienhof</p>
				<h1>Milch, Felder, Menschen – alles aus einer Familie</h1>
				<p>
					Wir arbeiten im Rhythmus der Natur, lieben unsere Tiere und teilen das, was wir produzieren. Ohne Shop,
					ohne Schnickschnack – einfach melden und vorbeikommen.
				</p>
				<div class="hero__ctas">
					<a href="#contact" class="btn btn--primary">Kontakt</a>
					<a href="#blog" class="btn btn--ghost">Blog lesen</a>
				</div>
				<div class="hero__chips">
					<span>📍 Landkreis Straubing-Bogen</span>
					<span>🕔 Milch & Eier nach Absprache</span>
					<span>🎓 Ausbildung ab Herbst 2026</span>
				</div>
			</div>
		</section>

		<section class="stats">
			{stats.map((item) => (
				<div class="stat">
					<p class="stat__value">{item.value}</p>
					<p class="stat__label">{item.label}</p>
				</div>
			))}
		</section>

		<section class="pillars">
			{pillars.map((pillar) => (
				<article class="pillar">
					<span class="pillar__icon">{pillar.icon}</span>
					<h3>{pillar.title}</h3>
					<p>{pillar.description}</p>
				</article>
			))}
		</section>

		<section class="story">
			<div class="story__gallery">
				{gallery.map((item) => (
					<figure>
						<img src={item.image} alt={item.title} loading="lazy" width="480" height="600" />
						<figcaption>{item.title}</figcaption>
					</figure>
				))}
			</div>
			<div class="story__timeline">
				<p class="eyebrow">Ein Tag am Hof</p>
				<h2>Routinen, die Haltung zeigen</h2>
				<ul>
					{timeline.map((item) => (
						<li>
							<div>
								<strong>{item.time}</strong>
								<h3>{item.title}</h3>
							</div>
							<p>{item.text}</p>
						</li>
					))}
				</ul>
			</div>
		</section>

		<section class="goods-jobs" id="direct">
			<div class="goods">
				<p class="eyebrow">Direkt vom Hof</p>
				<h2>Milch & Eier? Einfach anfragen.</h2>
				<div class="goods__cards">
					{farmGoods.map((good) => (
						<article>
							<h3>{good.title}</h3>
							<p>{good.detail}</p>
							<small>{good.note}</small>
						</article>
					))}
				</div>
				<a class="text-link" href="#contact">Anfragen & Termin abstimmen →</a>
			</div>
			<div class="jobs" id="jobs">
				<p class="eyebrow">Ausbildung & Mitarbeit</p>
				<h2>{jobOffer.title}</h2>
				<p>{jobOffer.intro}</p>
				<ul>
					{jobOffer.bullets.map((bullet) => (
						<li>{bullet}</li>
					))}
				</ul>
				<button class="btn btn--primary" type="button" onclick="window.location='#contact'">
					Jetzt anfragen
				</button>
			</div>
		</section>

		<section class="blog-contact" id="blog">
			<div class="blog">
				<p class="eyebrow">Blog & Geschichten</p>
				<h2>Was uns beschäftigt</h2>
				<div class="blog__grid">
					{posts.map((post) => (
						<article>
							<p class="post__meta">{post.date} · {post.readingTime}</p>
							<h3>{post.title}</h3>
							<p>{post.summary}</p>
							<button class="text-link" type="button">Beitrag folgt</button>
						</article>
					))}
				</div>
			</div>
			<div class="contact-card">
				<p class="eyebrow">Kontakt</p>
				<h2>Einfach melden & vorbeikommen</h2>
				<p>Göttl Hof · Niederbayern (genaue Adresse bei Anfrage)</p>
				<ul>
					<li>Mail: info@goettl-agrar.de</li>
					<li>Telefon: +49 (0) 000 000000</li>
					<li>Instagram: @goettlhof (reserviert)</li>
				</ul>
				<form>
					<input type="text" placeholder="Name" />
					<input type="email" placeholder="E-Mail" />
					<textarea rows="4" placeholder="Was dürfen wir vorbereiten?"></textarea>
					<button class="btn btn--ghost" type="button">Nachricht senden</button>
				</form>
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		margin: 0;
		background: #f7f5f0;
		color: #1f2220;
		font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	.page {
		display: flex;
		flex-direction: column;
		gap: 4rem;
		padding: clamp(1.5rem, 4vw, 4rem);
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.25em;
		font-size: 0.75rem;
		color: #2c5c46;
		margin-bottom: 0.8rem;
	}

	.hero {
		position: relative;
		border-radius: 2rem;
		min-height: 70vh;
		overflow: hidden;
		background: #13261b;
		color: #fff;
		padding: clamp(2.5rem, 6vw, 5rem);
		background-image: linear-gradient(120deg, rgba(10, 20, 15, 0.8), rgba(12, 35, 24, 0.5)),
			url("https://images.unsplash.com/photo-1473445361085-b9a07f55608b?auto=format&fit=crop&w=1800&q=80");
		background-size: cover;
		background-position: center;
	}

	.hero__overlay {
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at 20% 20%, rgba(255, 255, 255, 0.2), transparent 45%);
	}

	.hero__inner {
		position: relative;
		max-width: 720px;
		z-index: 1;
	}

	.hero h1 {
		font-family: "Playfair Display", serif;
		font-size: clamp(2.6rem, 5vw, 4.8rem);
		margin: 0 0 1rem;
	}

	.hero p {
		font-size: 1.2rem;
		line-height: 1.8;
	}

	.hero__ctas {
		margin: 2rem 0 1.5rem;
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.hero__chips {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
	}

	.hero__chips span {
		background: rgba(255, 255, 255, 0.15);
		padding: 0.4rem 0.9rem;
		border-radius: 999px;
		font-size: 0.9rem;
	}

	.btn {
		border-radius: 999px;
		padding: 0.75rem 1.8rem;
		font-weight: 600;
		border: 1px solid transparent;
		cursor: pointer;
		text-decoration: none;
	}

	.btn--primary {
		background: #e1c16e;
		color: #1a1d18;
	}

	.btn--ghost {
		border-color: rgba(255, 255, 255, 0.8);
		color: inherit;
		background: transparent;
	}

	.stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
		gap: 1rem;
	}

	.stat {
		background: #fff;
		border-radius: 1.4rem;
		padding: 1.4rem;
		text-align: center;
		box-shadow: 0 20px 40px rgba(19, 30, 26, 0.08);
	}

	.stat__value {
		font-size: 1.6rem;
		font-weight: 600;
		margin: 0;
	}

	.stat__label {
		margin: 0.2rem 0 0;
		color: #5f615f;
	}

	.pillars {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.25rem;
	}

	.pillar {
		background: #ffffff;
		border-radius: 1.5rem;
		padding: 1.5rem;
		border: 1px solid rgba(33, 94, 61, 0.12);
	}

	.pillar__icon {
		font-size: 2rem;
	}

	.story {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
		gap: 2rem;
		align-items: stretch;
	}

	.story__gallery {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.story__gallery figure {
		margin: 0;
		position: relative;
		overflow: hidden;
		border-radius: 1.3rem;
	}

	.story__gallery img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.6s ease;
	}

	.story__gallery figure:hover img {
		transform: scale(1.05);
	}

	.story__gallery figcaption {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 1rem;
		color: #fff;
		background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.7));
	}

	.story__timeline {
		background: #13261b;
		color: #f6f4ef;
		border-radius: 1.8rem;
		padding: 2rem;
	}

	.story__timeline ul {
		list-style: none;
		padding: 0;
		margin: 1.5rem 0 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.story__timeline li {
		display: flex;
		gap: 1rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.15);
		padding-bottom: 1rem;
	}

	.story__timeline strong {
		font-size: 1.2rem;
	}

	.goods-jobs {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 2rem;
	}

	.goods,
	.jobs {
		background: #fff;
		border-radius: 1.8rem;
		padding: 2rem;
		box-shadow: 0 25px 45px rgba(18, 29, 23, 0.08);
	}

	.goods__cards {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		margin-bottom: 1rem;
	}

	.goods__cards article {
		border: 1px solid rgba(33, 94, 61, 0.15);
		border-radius: 1rem;
		padding: 1rem 1.2rem;
	}

	.goods__cards small {
		color: #6c6e6b;
	}

	.jobs ul {
		list-style: none;
		padding: 0;
		margin: 1rem 0;
	}

	.jobs li {
		margin-bottom: 0.5rem;
		position: relative;
		padding-left: 1.5rem;
	}

	.jobs li::before {
		content: "→";
		position: absolute;
		left: 0;
		color: #2c5c46;
	}

	.blog-contact {
		display: grid;
		grid-template-columns: 1.4fr 1fr;
		gap: 2rem;
	}

	.blog__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.blog__grid article {
		background: #fff;
		border-radius: 1.4rem;
		padding: 1.4rem;
		border: 1px solid rgba(33, 94, 61, 0.08);
	}

	.post__meta {
		font-size: 0.8rem;
		letter-spacing: 0.2em;
		text-transform: uppercase;
		color: #7d7f7c;
	}

	.text-link {
		background: none;
		border: none;
		color: #2c5c46;
		font-weight: 600;
		cursor: pointer;
		padding: 0;
	}

	.contact-card {
		background: linear-gradient(180deg, #2f4738, #1b261f);
		color: #fefdf8;
		border-radius: 1.8rem;
		padding: 2rem;
		box-shadow: 0 30px 50px rgba(10, 16, 13, 0.35);
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.contact-card ul {
		list-style: none;
		padding: 0;
		margin: 0;
		line-height: 1.8;
	}

	.contact-card form {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
	}

	.contact-card input,
	.contact-card textarea {
		border: none;
		border-radius: 0.8rem;
		padding: 0.8rem 1rem;
		font-family: inherit;
	}

	@media (max-width: 960px) {
		.story,
		.blog-contact {
			grid-template-columns: 1fr;
		}
	}
</style>
