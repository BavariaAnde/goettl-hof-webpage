---
import Layout from "../layouts/Layout.astro";

const asset = (path) => `${import.meta.env.BASE_URL}${path.replace(/^\//, "")}`;

const stats = [
	{ label: "Milchkühe", value: "≈ 120" },
	{ label: "Hektar", value: "85 ha" },
	{ label: "Familie", value: "3 Generationen" },
	{ label: "Ausbildung", value: "Start 1. August" }
];

const cornerstones = [
	{
		title: "Milchvieh",
		description: "Ruhige Herde, Laufstall, viel Handarbeit und Sensoren, die uns unterstützen.",
		bullets: ["Melken früh & abends", "Eigenes Futter", "Tierwohl zuerst"]
	},
	{
		title: "Felder & Maschinen",
		description: "Grünlandpflege, Getreide, Mais und Nachbarschaftshilfe – Technik aus Oberbubach.",
		bullets: ["Fendt, Claas, Pöttinger", "Bodenschonende Bearbeitung", "Helfen wenn wer Hilfe braucht"]
	}
];

const gallery = [
	{ title: "Sommer über Oberbubach", image: asset("images/hof-panorama-sommer.webp") },
	{ title: "Winterruhe", image: asset("images/hof-panorama-winter.webp") },
	{ title: "Blick Richtung Silo", image: asset("images/hof-sicht-silo.webp") },
	{ title: "Schwadern am Abend", image: asset("images/schwadern.webp") },
	{ title: "Fendt beim Grubbern", image: asset("images/fendt-grubern.webp") },
	{ title: "Mähdrescher in Aktion", image: asset("images/mähdrescher.webp") }
];

const posts = [
	{
		title: "Was sich 2026 verändert",
		date: "Blog folgt",
		summary: "Aktuelles aus Stall & Feld – wir füllen das, sobald die ersten Beiträge stehen."
	},
	{
		title: "Fragen zur Ausbildung?",
		date: "Ab August",
		summary: "Kurz erklärt, wie du Teil vom Hof wirst und was dich erwartet."
	}
];

const faqs = [
	{
		question: "Kann ich Milch oder Eier kaufen?",
		answer: "Ja – Rohmilch täglich ab 18 Uhr, Eier Freitag & Samstag. Bitte kurz per Telefon oder Mail anmelden."
	},
	{
		question: "Wie läuft die Ausbildung?",
		answer: "Start immer 1. August. Wir nehmen 1-2 Personen, Wohnmöglichkeit nach Absprache. Melde dich frühzeitig."
	},
	{
		question: "Darf ich spontan vorbeikommen?",
		answer: "Bitte vorher anklingeln – dann nehmen wir uns Zeit und du stehst niemandem im Weg."
	}
];
---
<Layout
	title="Göttl Hof – Oberbubach/ Roßbach"
	description="Familienbetrieb in Oberbubach (Roßbach): Milchvieh, Felder, Ausbildung und Direktvermarktung nach Absprache."
>
	<main class="page">
		<section class="hero">
			<div class="hero__text">
				<p class="eyebrow">Oberbubach · Gemeinde Roßbach (Niederbayern)</p>
				<h1>Göttl Hof – Milch, Felder & Ausbildung aus einer Hand</h1>
				<p>
					Wir arbeiten hier als Familie, bilden jedes Jahr aus und geben auf Anfrage Rohmilch und Eier direkt vom Hof
					weiter. Kein Shop, kein ChiChi – einfach anrufen oder schreiben.
				</p>
				<div class="hero__actions">
					<a class="btn" href="#contact">Kontakt aufnehmen</a>
					<a class="link" href="#ausbildung">Ausbildung ab 1. August →</a>
				</div>
				<div class="hero__note">
					<p>Direktvermarktung ist möglich, solange der Vorrat reicht. Bitte vorher melden.</p>
				</div>
			</div>
			<div class="hero__photo">
				<img src={asset("images/hof-panorama-sicht2-januar.webp")} alt="Göttl Hof im Winter" width="720" height="480" />
			</div>
		</section>

		<section class="stats">
			{stats.map((item) => (
				<div>
					<p class="stats__value">{item.value}</p>
					<p class="stats__label">{item.label}</p>
				</div>
			))}
		</section>

		<section class="cornerstones" id="hof">
			<div class="cornerstones__text">
				<h2>Was unseren Hof ausmacht</h2>
				<p>
					Wir stehen morgens mit den Kühen auf, helfen Nachbarn mit Maschinen, führen Buch über Felder und geben
					Erfahrung weiter. Wer uns besuchen will, soll ein Gefühl bekommen, wie wir ticken: ruhig, ehrlich und
					bodenständig.
				</p>
			</div>
			<div class="cornerstones__cards">
				{cornerstones.map((block) => (
					<article>
						<h3>{block.title}</h3>
						<p>{block.description}</p>
						<ul>
							{block.bullets.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="gallery" aria-label="Hof Impressionen">
			{gallery.map((shot) => (
				<figure>
					<img src={shot.image} alt={shot.title} loading="lazy" width="480" height="360" />
					<figcaption>{shot.title}</figcaption>
				</figure>
			))}
		</section>

		<section class="training" id="ausbildung">
			<div>
				<h2>Ausbildung & Mitarbeit</h2>
				<p>
					Start ist jedes Jahr am <strong>1. August</strong>. Wir nehmen 1–2 Personen, die Landwirtschaft wirklich
					lernen wollen. Eigene Projekte, Umgang mit Tieren und Maschinen, wohnen nach Absprache.
				</p>
				<ul>
					<li>Ausbildungsplatz frei ab August 2026</li>
					<li>Vor- oder Schnuppertage möglich</li>
					<li>Bewerbung einfach per Mail oder persönlichem Gespräch</li>
				</ul>
			</div>
			<div class="training__cta">
				<p>Sprich uns an, erzähl kurz wer du bist – wir melden uns fix.</p>
				<a class="btn" href="#contact">Ausbildung anfragen</a>
			</div>
		</section>

		<section class="faq">
			<h2>Fragen, die wir oft hören</h2>
			<div class="faq__grid">
				{faqs.map((item) => (
					<article>
						<h3>{item.question}</h3>
						<p>{item.answer}</p>
					</article>
				))}
			</div>
		</section>

		<section class="blog-contact" id="blog">
			<div class="blog">
				<h2>Blog & Aktuelles</h2>
				<div class="blog__cards">
					{posts.map((post) => (
						<article>
							<p class="blog__date">{post.date}</p>
							<h3>{post.title}</h3>
							<p>{post.summary}</p>
							<button class="link" type="button">Mehr folgt</button>
						</article>
					))}
				</div>
			</div>
			<div class="contact" id="contact">
				<h2>Kontakt & Direktvermarktung</h2>
				<p>Oberbubach  · 94333 Roßbach – genaue Wegbeschreibung nach Anfrage</p>
				<ul>
					<li>Mail: info@goettl-agrar.de</li>
					<li>Telefon: +49 (0) 000 000000</li>
				</ul>
				<form>
					<input type="text" placeholder="Name" />
					<input type="email" placeholder="E-Mail" />
					<textarea rows="4" placeholder="Worum geht's? Milch, Eier, Ausbildung?"></textarea>
					<button class="btn" type="button">Nachricht senden</button>
				</form>
				<small>Bitte gib an, wann du Zeit hast – dann planen wir dich fix ein.</small>
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		margin: 0;
		background: #f4efe6;
		color: #1f1c17;
		font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	.page {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
		padding: clamp(1.5rem, 4vw, 4rem);
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.22em;
		font-size: 0.75rem;
		color: #5b6f58;
	}

	.hero {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
		align-items: center;
		background: #fff;
		border-radius: 1.5rem;
		padding: clamp(1.5rem, 3vw, 3rem);
		box-shadow: 0 15px 35px rgba(19, 23, 17, 0.08);
	}

	.hero__text h1 {
		font-family: "Playfair Display", serif;
		font-size: clamp(2.2rem, 4vw, 3.5rem);
		margin: 0.3rem 0 1rem;
	}

	.hero__text p {
		line-height: 1.7;
		max-width: 60ch;
	}

	.hero__photo img {
		width: 100%;
		border-radius: 1.2rem;
		object-fit: cover;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin: 1.5rem 0 1rem;
	}

	.hero__note {
		background: #f0eadc;
		padding: 0.8rem 1rem;
		border-radius: 0.8rem;
		font-size: 0.95rem;
	}

	.btn {
		background: #cfa962;
		color: #1f1c17;
		border: none;
		border-radius: 999px;
		padding: 0.8rem 1.6rem;
		font-weight: 600;
		cursor: pointer;
		text-decoration: none;
	}

	.link {
		background: none;
		border: none;
		color: #4b5f49;
		font-weight: 600;
		cursor: pointer;
		text-decoration: none;
	}

	.stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 1rem;
	}

	.stats > div {
		background: #fff;
		border-radius: 1rem;
		padding: 1rem;
		text-align: center;
		border: 1px solid #ebe1cf;
	}

	.stats__value {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 600;
	}

	.stats__label {
		margin: 0.2rem 0 0;
		color: #666059;
	}

	.cornerstones {
		display: grid;
		grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
		gap: 2rem;
		align-items: start;
	}

	.cornerstones__cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}

	.cornerstones__cards article {
		background: #fff;
		border-radius: 1.2rem;
		padding: 1.3rem;
		border: 1px solid #ebe1cf;
	}

	.cornerstones__cards ul {
		padding-left: 1.2rem;
		color: #5c5a56;
	}

	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 0.8rem;
	}

	.gallery figure {
		margin: 0;
		background: #fff;
		border-radius: 1rem;
		overflow: hidden;
		border: 1px solid #ebe1cf;
	}

	.gallery img {
		width: 100%;
		height: 200px;
		object-fit: cover;
	}

	.gallery figcaption {
		padding: 0.7rem 1rem;
		font-size: 0.9rem;
		color: #4a4a44;
	}

	.training {
		background: #fff;
		border-radius: 1.5rem;
		padding: 2rem;
		border: 1px solid #eadfc9;
		display: grid;
		grid-template-columns: minmax(0, 2fr) minmax(220px, 1fr);
		gap: 1.5rem;
	}

	.training ul {
		padding-left: 1.2rem;
	}

	.training__cta {
		background: #f0eadc;
		padding: 1.5rem;
		border-radius: 1rem;
	}

	.faq {
		background: #fff;
		border-radius: 1.2rem;
		padding: 2rem;
		border: 1px solid #eadfc9;
	}

	.faq__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.faq__grid article {
		background: #f8f4ed;
		border-radius: 1rem;
		padding: 1rem;
	}

	.blog-contact {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 360px);
		gap: 2rem;
	}

	.blog__cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.blog__cards article {
		background: #fff;
		border-radius: 1rem;
		padding: 1.2rem;
		border: 1px solid #ebe1cf;
	}

	.blog__date {
		font-size: 0.85rem;
		color: #7a746d;
	}

	.contact {
		background: #fff;
		border-radius: 1.5rem;
		padding: 1.5rem;
		border: 1px solid #eadfc9;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.contact ul {
		list-style: none;
		padding: 0;
		margin: 0;
		line-height: 1.8;
	}

	.contact form {
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
	}

	.contact input,
	.contact textarea {
		border-radius: 0.8rem;
		border: 1px solid #d8cbb3;
		padding: 0.75rem 1rem;
		font-family: inherit;
	}

	.contact small {
		color: #6b645b;
	}

	@media (max-width: 900px) {
		.cornerstones {
			grid-template-columns: 1fr;
		}

		.blog-contact {
			grid-template-columns: 1fr;
		}

		.training {
			grid-template-columns: 1fr;
		}
	}
</style>

