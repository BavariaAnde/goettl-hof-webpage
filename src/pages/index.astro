---
import Layout from "../layouts/Layout.astro";

const baseUrl = (import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
const asset = (path) => `${baseUrl}/${path.replace(/^\/+/ , "")}`;

const stats = [
	{ label: "Milchkühe", value: "≈ 70" },
	{ label: "Landwirtschaft", value: "100 ha" },
	{ label: "Forst", value: "12 ha" },
	{ label: "Ausbildung", value: "Start 1. August" }
];

const cornerstones = [
	{
		title: "Milchvieh",
		description: "Ruhige Herde, Laufstall, viel Handarbeit und Sensoren, die uns unterstützen.",
		bullets: ["Melken früh & abends", "Eigenes Futter", "Tierwohl zuerst"]
	},
	{
		title: "Felder & Maschinen",
		description: "Grünlandpflege, Getreide, Mais und Nachbarschaftshilfe – Technik aus Oberbubach.",
		bullets: ["Fendt, Claas, Pöttinger", "Bodenschonende Bearbeitung", "Helfen wenn wer Hilfe braucht"]
	}
];

const equipment = [
	{
		title: "Zugmaschinen",
		details: ["Fendt (300er & 500er Reihe)", "Telelader für Hofarbeiten", "Breitreifen für bodenschonenden Silageeinsatz"]
	},
	{
		title: "Ernte & Pflege",
		details: ["Pöttinger Schwader", "Neue Gaspardo Drillkombination", "Ballen- & Transporttechnik"]
	},
	{
		title: "Dienstleistungen",
		details: ["Grünlandpflege & Bodenbearbeitung", "Mais-/Getreideernte", "Nachbarschaftshilfe nach Absprache"]
	}
];

const trainingSlots = [
	{ year: "2026", status: "belegt", note: "Platz vergeben" },
	{ year: "2027", status: "belegt", note: "Platz vergeben" },
	{ year: "2028", status: "belegt", note: "Platz vergeben" },
	{ year: "2029", status: "frei", note: "Frei ab 01.08.2029" }
];

const gallery = [
	{ title: "Sommer über Oberbubach", image: asset("images/hof-panorama-sommer.webp") },
	{ title: "Winterruhe", image: asset("images/hof-panorama-winter.webp") },
	{ title: "Blick Richtung Silo", image: asset("images/hof-sicht-silo.webp") },
	{ title: "Schwadern am Abend", image: asset("images/schwadern.webp") },
	{ title: "Fendt beim Grubbern", image: asset("images/fendt-grubern.webp") },
	{ title: "Mähdrescher in Aktion", image: asset("images/mähdrescher.webp") }
];

const seasons = [
	{
		title: "Frühjahr",
		timeframe: "März – Mai",
		tasks: ["Böden lockern & nachsäen", "Sensoren & Stalltechnik warten", "Jungvieh auf die Weiden vorbereiten"]
	},
	{
		title: "Sommer",
		timeframe: "Juni – August",
		tasks: ["Grünlandpflege & Heu einbringen", "Maisbestand kontrollieren", "Nachbarschaftshilfe mit Maschinen"]
	},
	{
		title: "Herbst",
		timeframe: "September – November",
		tasks: ["Mais- und Getreideernte", "Silagen anlegen", "Felder für den Winter vorbereiten"]
	},
	{
		title: "Winter",
		timeframe: "Dezember – Februar",
		tasks: ["Ruhe im Stall & Kälberbetreuung", "Maschinenservice", "Planung fürs nächste Ausbildungsjahr"]
	}
];

const posts = [
	{
		title: "Was sich 2026 verändert",
		date: "Blog folgt",
		summary: "Aktuelles aus Stall & Feld – wir füllen das, sobald die ersten Beiträge stehen."
	},
	{
		title: "Fragen zur Ausbildung?",
		date: "Ab August",
		summary: "Kurz erklärt, wie du Teil vom Hof wirst und was dich erwartet."
	}
];

const faqs = [
	{
		question: "Wie melde ich meinen Besuch an?",
		answer: "Kurz anrufen oder eine Mail schicken – wir sprechen einen Termin ab und sorgen dafür, dass jemand Zeit hat."
	},
	{
		question: "Wie läuft die Ausbildung?",
		answer: "Start immer 1. August. Wir nehmen 1-2 Personen, Wohnmöglichkeit nach Absprache. Melde dich frühzeitig."
	},
	{
		question: "Darf ich spontan vorbeikommen?",
		answer: "Bitte vorher anklingeln – dann nehmen wir uns Zeit und du stehst niemandem im Weg."
	}
];

const visit = {
	address: "Oberbubach · 94439 Roßbach",
	googleMaps: "https://maps.google.com/maps?q=Oberbubach%2C%2094439%20Ro%C3%9Fbach&output=embed",
	mapsLink: "https://maps.app.goo.gl/4ouS1fks4bA7Rh1s5"
};
---
<Layout
	title="Göttl Hof – Oberbubach/ Roßbach"
	description="Familienbetrieb in Oberbubach (Roßbach): Milchvieh, Felder, Ausbildung und Nachbarschaftshilfe nach Absprache."
>
	<main class="page">
		<section class="hero">
			<div class="hero__text">
				<p class="eyebrow">Oberbubach · Gemeinde Roßbach (Niederbayern)</p>
				<h1>Göttl Hof – Milch, Felder & Ausbildung aus einer Hand</h1>
				<p>
					Wir arbeiten hier als Familie, bilden jedes Jahr aus und helfen Nachbarn mit Technik und Erfahrung.
					Kein Shop, kein ChiChi – einfach anrufen oder schreiben.
				</p>
				<div class="hero__actions">
					<a class="btn" href="#contact">Kontakt aufnehmen</a>
					<a class="link" href="#ausbildung">Ausbildung ab 1. August →</a>
				</div>
				<div class="hero__note">
					<p>Besuche und Gespräche bitte kurz vorher ankündigen – dann nehmen wir uns Zeit für euch.</p>
				</div>
			</div>
			<div class="hero__photo">
				<img src={asset("images/hof-panorama-sicht2-januar.webp")} alt="Göttl Hof im Winter" width="720" height="480" />
			</div>
		</section>

		<section class="stats">
			{stats.map((item) => (
				<div>
					<p class="stats__value">{item.value}</p>
					<p class="stats__label">{item.label}</p>
				</div>
			))}
		</section>

		<section class="cornerstones" id="hof">
			<div class="cornerstones__text">
				<h2>Was unseren Hof ausmacht</h2>
				<p>
					Wir stehen morgens mit den Kühen auf, helfen Nachbarn mit Maschinen, führen Buch über Felder und geben
					Erfahrung weiter. Wer uns besuchen will, soll ein Gefühl bekommen, wie wir ticken: ruhig, ehrlich und
					bodenständig.
				</p>
			</div>
			<div class="cornerstones__cards">
				{cornerstones.map((block) => (
					<article>
						<h3>{block.title}</h3>
						<p>{block.description}</p>
						<ul>
							{block.bullets.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="equipment">
			<div>
				<h2>Maschinen & Leistungen</h2>
				<p>
					Moderne Technik hilft uns, zuverlässig zu liefern – auf den eigenen Flächen wie auch bei Nachbarn. Alles
					nach Absprache und so, dass es zu Hof und Boden passt.
				</p>
			</div>
			<div class="equipment__grid">
				{equipment.map((card) => (
					<article>
						<h3>{card.title}</h3>
						<ul>
							{card.details.map((detail) => (
								<li>{detail}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="gallery" aria-label="Hof Impressionen">
			{gallery.map((shot) => (
				<figure>
					<img src={shot.image} alt={shot.title} loading="lazy" width="480" height="360" />
					<figcaption>{shot.title}</figcaption>
				</figure>
			))}
		</section>

		<section class="seasons" aria-label="Unser Jahr am Hof">
			<div class="seasons__intro">
				<h2>Unser Jahr am Hof</h2>
				<p>Was wann passiert? Ein schneller Überblick über Feldarbeit, Stall und Zeiten, in denen wir besonders gut erreichbar sind.</p>
			</div>
			<div class="seasons__grid">
				{seasons.map((season) => (
					<article>
						<p class="seasons__timeframe">{season.timeframe}</p>
						<h3>{season.title}</h3>
						<ul>
							{season.tasks.map((task) => (
								<li>{task}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="training" id="ausbildung">
			<div>
				<h2>Ausbildung & Mitarbeit</h2>
				<p>
					Start ist jedes Jahr am <strong>1. August</strong>. Wir nehmen 1–2 Personen, die Landwirtschaft wirklich
					lernen wollen. Eigene Projekte, Umgang mit Tieren und Maschinen, wohnen nach Absprache. Aktuell sind alle
					Plätze bis 2028 vergeben – frei wird es wieder ab 01.08.2029.
				</p>
				<div class="training__slots" aria-label="Ausbildungsplätze">
					{trainingSlots.map((slot) => (
						<div
							class={`training__slot ${slot.status === "frei" ? "training__slot--free" : "training__slot--booked"}`}
						>
							<div>
								<p class="training__slot-year">{slot.year}</p>
								<p class="training__slot-note">{slot.note}</p>
							</div>
							<span class="training__slot-badge" aria-label={slot.status === "frei" ? "frei" : "belegt"}>
								{slot.status === "frei" ? "frei" : "belegt"}
							</span>
						</div>
					))}
				</div>
			</div>
			<div class="training__cta">
				<img
					src={asset("images/kuh-mit-kalb.jpg")}
					alt="Kuh mit Kalb im Stall"
					loading="lazy"
					width="360"
					height="240"
					class="training__cta-image"
				/>
				<p>Sprich uns an, erzähl kurz wer du bist – wir melden uns fix.</p>
				<a class="btn" href="#contact">Ausbildung anfragen</a>
			</div>
		</section>

		<section class="faq">
			<h2>Fragen, die wir oft hören</h2>
			<div class="faq__grid">
				{faqs.map((item) => (
					<article>
						<h3>{item.question}</h3>
						<p>{item.answer}</p>
					</article>
				))}
			</div>
		</section>

		<section class="visit">
			<div class="visit__info">
				<h2>Anfahrt & Besuch</h2>
				<p>
					Wir liegen direkt in <strong>{visit.address}</strong>. Melde dich kurz, bevor du losfährst – dann stellen wir
					sicher, dass jemand Zeit hat und Hof & Tiere bereit sind.
				</p>
				<ul>
					<li>Besuche bitte vorher anmelden</li>
					<li>Parken am Hof – bitte langsam anfahren</li>
					<li>Navigation: „Göttl Hof Oberbubach"</li>
				</ul>
				<a class="link" href={visit.mapsLink} target="_blank" rel="noreferrer">Navigation öffnen →</a>
			</div>
			<div class="visit__map">
				<iframe
					src={visit.googleMaps}
					loading="lazy"
					title="Karte Oberbubach"
					allowfullscreen
				></iframe>
			</div>
		</section>

		<section class="blog-contact" id="blog">
			<div class="blog">
				<h2>Blog & Aktuelles</h2>
				<div class="blog__cards">
					{posts.map((post) => (
						<article>
							<p class="blog__date">{post.date}</p>
							<h3>{post.title}</h3>
							<p>{post.summary}</p>
							<button class="link" type="button">Mehr folgt</button>
						</article>
					))}
				</div>
			</div>
			<div class="contact" id="contact">
				<h2>Kontakt & Rückfragen</h2>
				<p>{visit.address} – genaue Wegbeschreibung nach Anfrage</p>
				<ul>
					<li>Mail: info@goettl-agrar.de</li>
					<li>Telefon: +49 (0) 000 000000</li>
				</ul>
				<div class="contact__cta">
					<p>Am besten erreichbar täglich zwischen 18 und 20 Uhr.</p>
					<div class="contact__cta-buttons">
						<a class="btn contact__cta-btn" href="tel:+49000000000">Anrufen</a>
						<a class="btn contact__cta-btn contact__cta-btn--outline" href="mailto:info@goettl-agrar.de">Mail schreiben</a>
						<a class="btn contact__cta-btn contact__cta-btn--whatsapp" href="https://wa.me/49000000000" target="_blank" rel="noreferrer">WhatsApp</a>
					</div>
				</div>
				<form>
					<input type="text" placeholder="Name" />
					<input type="email" placeholder="E-Mail" />
					<textarea rows="4" placeholder="Worum geht's? Ausbildung, Maschinenhilfe, Besuch?"></textarea>
					<button class="btn" type="button">Nachricht senden</button>
				</form>
				<small>Bitte gib an, wann du Zeit hast – dann planen wir dich fix ein.</small>
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		margin: 0;
		background: #f4efe6;
		color: #1f1c17;
		font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	}

	.page {
		display: flex;
		flex-direction: column;
		gap: 3.5rem;
		padding: clamp(1.5rem, 4vw, 4rem);
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.22em;
		font-size: 0.75rem;
		color: #5b6f58;
	}

	.hero {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
		gap: 2rem;
		align-items: center;
		background: #fff;
		border-radius: 1.5rem;
		padding: clamp(1.5rem, 3vw, 3rem);
		box-shadow: 0 15px 35px rgba(19, 23, 17, 0.08);
	}

	.hero__text h1 {
		font-family: "Playfair Display", serif;
		font-size: clamp(2.2rem, 4vw, 3.5rem);
		margin: 0.3rem 0 1rem;
	}

	.hero__text p {
		line-height: 1.7;
		max-width: 60ch;
	}

	.hero__photo img {
		width: 100%;
		border-radius: 1.2rem;
		object-fit: cover;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin: 1.5rem 0 1rem;
	}

	.hero__note {
		background: #f0eadc;
		padding: 0.8rem 1rem;
		border-radius: 0.8rem;
		font-size: 0.95rem;
	}

	.btn {
		background: #cfa962;
		color: #1f1c17;
		border: none;
		border-radius: 999px;
		padding: 0.8rem 1.6rem;
		font-weight: 600;
		cursor: pointer;
		text-decoration: none;
	}

	.link {
		background: none;
		border: none;
		color: #4b5f49;
		font-weight: 600;
		cursor: pointer;
		text-decoration: none;
	}

	.stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
		gap: 1rem;
	}

	.stats > div {
		background: #fff;
		border-radius: 1rem;
		padding: 1rem;
		text-align: center;
		border: 1px solid #ebe1cf;
	}

	.stats__value {
		margin: 0;
		font-size: 1.2rem;
		font-weight: 600;
	}

	.stats__label {
		margin: 0.2rem 0 0;
		color: #666059;
	}

	.cornerstones {
		display: grid;
		grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
		gap: 2rem;
		align-items: start;
	}

	.cornerstones__cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1rem;
	}

	.cornerstones__cards article {
		background: #fff;
		border-radius: 1.2rem;
		padding: 1.3rem;
		border: 1px solid #ebe1cf;
	}

	.cornerstones__cards ul {
		padding-left: 1.2rem;
		color: #5c5a56;
	}

	.equipment {
		background: #fff;
		border-radius: 1.5rem;
		padding: 2rem;
		border: 1px solid #eadfc9;
		box-shadow: 0 10px 25px rgba(18, 23, 17, 0.05);
	}

	.equipment__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
		margin-top: 1.5rem;
	}

	.equipment__grid article {
		background: #f8f4ed;
		border-radius: 1rem;
		padding: 1.2rem;
	}

	.equipment__grid ul {
		padding-left: 1.2rem;
	}

	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 0.8rem;
	}

	.gallery figure {
		margin: 0;
		background: #fff;
		border-radius: 1rem;
		overflow: hidden;
		border: 1px solid #ebe1cf;
	}

	.gallery img {
		width: 100%;
		height: 200px;
		object-fit: cover;
	}

	.gallery figcaption {
		padding: 0.7rem 1rem;
		font-size: 0.9rem;
		color: #4a4a44;
	}

	.seasons {
		background: #fff;
		border-radius: 1.5rem;
		padding: 2rem;
		border: 1px solid #eadfc9;
		box-shadow: 0 10px 25px rgba(18, 23, 17, 0.05);
	}

	.seasons__intro {
		max-width: 520px;
		margin-bottom: 1.5rem;
	}

	.seasons__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1rem;
	}

	.seasons__grid article {
		background: #f8f4ed;
		border-radius: 1rem;
		padding: 1.2rem;
		border: 1px solid #eadfc9;
	}

	.seasons__timeframe {
		margin: 0;
		font-size: 0.85rem;
		letter-spacing: 0.05em;
		text-transform: uppercase;
		color: #5f6c58;
	}

	.seasons__grid ul {
		padding-left: 1.1rem;
		color: #5c5a56;
	}

	.training {
		background: #fff;
		border-radius: 1.5rem;
		padding: 2rem;
		border: 1px solid #eadfc9;
		display: grid;
		grid-template-columns: minmax(0, 2fr) minmax(220px, 1fr);
		gap: 1.5rem;
	}

	.training__slots {
		display: flex;
		flex-direction: column;
		gap: 0.8rem;
		margin-top: 1rem;
	}

	.training__slot {
		background: #f8f4ed;
		border: 1px solid #eadfc9;
		border-radius: 1rem;
		padding: 0.9rem 1.2rem;
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 1rem;
	}

	.training__slot-year {
		margin: 0;
		font-weight: 600;
		font-size: 1rem;
	}

	.training__slot-note {
		margin: 0.1rem 0 0;
		color: #5c5a56;
		font-size: 0.9rem;
	}

	.training__slot-badge {
		text-transform: uppercase;
		font-size: 0.75rem;
		letter-spacing: 0.1em;
		padding: 0.35rem 0.8rem;
		border-radius: 999px;
		font-weight: 600;
	}

	.training__slot--booked .training__slot-badge {
		background: #e4d7c0;
		color: #5f574d;
	}

	.training__slot--free .training__slot-badge {
		background: #c5e6c0;
		color: #204419;
	}

	.training__cta {
		background: #f0eadc;
		padding: 1.5rem;
		border-radius: 1rem;
	}

	.training__cta-image {
		width: 100%;
		border-radius: 0.9rem;
		object-fit: cover;
		margin-bottom: 1rem;
		border: 1px solid #e0d2b9;
	}

	.faq {
		background: #fff;
		border-radius: 1.2rem;
		padding: 2rem;
		border: 1px solid #eadfc9;
	}

	.faq__grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.faq__grid article {
		background: #f8f4ed;
		border-radius: 1rem;
		padding: 1rem;
	}

	.visit {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.5rem;
		background: #fff;
		border-radius: 1.5rem;
		padding: 2rem;
		border: 1px solid #eadfc9;
	}

	.visit__info ul {
		padding-left: 1.2rem;
		color: #5a564f;
	}

	.visit__map iframe {
		width: 100%;
		border: none;
		height: 280px;
		border-radius: 1rem;
	}

	.blog-contact {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 360px);
		gap: 2rem;
	}

	.blog__cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.blog__cards article {
		background: #fff;
		border-radius: 1rem;
		padding: 1.2rem;
		border: 1px solid #ebe1cf;
	}

	.blog__date {
		font-size: 0.85rem;
		color: #7a746d;
	}

	.contact {
		background: #fff;
		border-radius: 1.5rem;
		padding: 1.5rem;
		border: 1px solid #eadfc9;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.contact ul {
		list-style: none;
		padding: 0;
		margin: 0;
		line-height: 1.8;
	}

	.contact form {
		display: flex;
		flex-direction: column;
		gap: 0.7rem;
	}

	.contact__cta {
		margin: 1rem 0;
		background: #f8f4ed;
		border: 1px solid #eadfc9;
		border-radius: 1rem;
		padding: 1rem 1.2rem;
	}

	.contact__cta-buttons {
		display: flex;
		flex-wrap: wrap;
