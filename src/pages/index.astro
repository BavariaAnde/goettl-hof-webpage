---
import Layout from "../layouts/Layout.astro";
import { blogPosts } from "../data/blogPosts";

const baseUrl = (import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
const asset = (path) => `${baseUrl}/${path.replace(/^\/+/ , "")}`;

const stats = [
	{ label: "Milchkühe", value: "≈ 70" },
	{ label: "Landwirtschaft", value: "100 ha" },
	{ label: "Forst", value: "12 ha" },
	{ label: "Ausbildung", value: "Start 1. August" }
];

const cornerstones = [
	{
		title: "Milchvieh",
		description: "Ruhige Herde, Laufstall, viel Handarbeit und Sensoren, die uns unterstützen.",
		bullets: ["Melken früh & abends", "Eigenes Futter", "Tierwohl zuerst"]
	},
	{
		title: "Felder & Maschinen",
		description: "Grünlandpflege, Getreide, Mais und Nachbarschaftshilfe – Technik aus Oberbubach.",
		bullets: ["Fendt, Claas, Pöttinger", "Bodenschonende Bearbeitung", "Helfen wenn wer Hilfe braucht"]
	}
];

const equipment = [
	{
		title: "Zugmaschinen",
		details: ["Fendt (300er & 500er Reihe)", "Telelader für Hofarbeiten", "Breitreifen für bodenschonenden Silageeinsatz"]
	},
	{
		title: "Ernte & Pflege",
		details: ["Pöttinger Schwader", "Neue Gaspardo Drillkombination", "Ballen- & Transporttechnik"]
	},
	{
		title: "Dienstleistungen",
		details: ["Grünlandpflege & Bodenbearbeitung", "Mais-/Getreideernte", "Nachbarschaftshilfe nach Absprache"]
	}
];

const trainingSlots = [
	{ year: "2026", status: "belegt", note: "Platz vergeben" },
	{ year: "2027", status: "belegt", note: "Platz vergeben" },
	{ year: "2028", status: "belegt", note: "Platz vergeben" },
	{ year: "2029", status: "frei", note: "Frei ab 01.08.2029" }
];

const gallery = [
	{ title: "Sommer über Oberbubach", image: asset("images/hof-panorama-sommer.webp") },
	{ title: "Winterruhe", image: asset("images/hof-panorama-winter.webp") },
	{ title: "Blick Richtung Silo", image: asset("images/hof-sicht-silo.webp") },
	{ title: "Schwadern am Abend", image: asset("images/schwadern.webp") },
	{ title: "Fendt beim Grubbern", image: asset("images/fendt-grubern.webp") },
	{ title: "Mähdrescher in Aktion", image: asset("images/mähdrescher.webp") }
];

const seasons = [
	{
		title: "Frühjahr",
		timeframe: "März – Mai",
		tasks: ["Böden lockern & nachsäen", "Sensoren & Stalltechnik warten", "Jungvieh auf die Weiden vorbereiten"]
	},
	{
		title: "Sommer",
		timeframe: "Juni – August",
		tasks: ["Grünlandpflege & Heu einbringen", "Maisbestand kontrollieren", "Nachbarschaftshilfe mit Maschinen"]
	},
	{
		title: "Herbst",
		timeframe: "September – November",
		tasks: ["Mais- und Getreideernte", "Silagen anlegen", "Felder für den Winter vorbereiten"]
	},
	{
		title: "Winter",
		timeframe: "Dezember – Februar",
		tasks: ["Ruhe im Stall & Kälberbetreuung", "Maschinenservice", "Planung fürs nächste Ausbildungsjahr"]
	}
];

const posts = blogPosts;



const faqs = [
	{
		question: "Wie melde ich meinen Besuch an?",
		answer: "Kurz anrufen oder eine Mail schicken – wir sprechen einen Termin ab und sorgen dafür, dass jemand Zeit hat."
	},
	{
		question: "Wie läuft die Ausbildung?",
		answer: "Start immer 1. August. Wir nehmen 1-2 Personen, Wohnmöglichkeit nach Absprache. Melde dich frühzeitig."
	},
	{
		question: "Darf ich spontan vorbeikommen?",
		answer: "Bitte vorher anklingeln – dann nehmen wir uns Zeit und du stehst niemandem im Weg."
	}
];

const visit = {
	address: "Oberbubach 1a · 94439 Roßbach",
	googleMaps: "https://maps.google.com/maps?q=Oberbubach%201a%2C%2094439%20Ro%C3%9Fbach&output=embed",
	mapsLink: "https://maps.app.goo.gl/qFSLV6DmF6jUsVT36"
};

const statsIcons = [
	`<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="13" rx="6" ry="4"/><path d="M6.5 9C4.5 9 3 10 3 11.5S4.5 14 6.5 14"/><path d="M17.5 9C19.5 9 21 10 21 11.5S19.5 14 17.5 14"/><path d="M8 9C7.5 7 6.5 6 5.5 5.5"/><path d="M16 9C16.5 7 17.5 6 18.5 5.5"/><line x1="9" y1="17" x2="9" y2="20"/><line x1="15" y1="17" x2="15" y2="20"/></svg>`,
	`<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
	`<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C8 10 5.9 16.17 3.82 19.34A1 1 0 0 0 4.63 21C6.4 20.12 10.14 18.5 12 15c1.37-2.37 1.37-4.42 2-6.2"/><path d="M17 8c.85 2.45 1.08 3.73 1 6C16.61 19.12 14 20.5 12 21"/><path d="M6 13c.5-2 1.5-3.5 4-4.5"/></svg>`,
	`<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`
];

// Season visual config (not modifying the seasons array)
const seasonMeta = [
	{ emoji: "🌱", color: "#5a9e40" },
	{ emoji: "☀️", color: "#c79a3a" },
	{ emoji: "🍂", color: "#b8542a" },
	{ emoji: "❄️", color: "#4a7b9d" }
];
---
<Layout
	title="Göttl Hof – Oberbubach/ Roßbach"
	description="Familienbetrieb in Oberbubach (Roßbach): Milchvieh, Felder, Ausbildung und Nachbarschaftshilfe nach Absprache."
>
	<!-- ===== STICKY NAVIGATION ===== -->
	<nav class="site-nav" aria-label="Hauptnavigation">
		<div class="nav__inner">
			<a class="nav__brand" href="#hof-top" aria-label="Göttl Hof – zurück zum Seitenanfang">
				<img src="/favicon.svg" class="nav__brand-icon" width="28" height="28" alt="" aria-hidden="true" />
				<span class="nav__brand-name">Göttl Hof</span>
			</a>

			<input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" />
			<div class="nav__actions">
				<button id="darkToggle" class="nav__dark-toggle" aria-label="Dark Mode umschalten" title="Dark Mode umschalten">
					<span class="toggle-icon toggle-icon--light">🌙</span>
					<span class="toggle-icon toggle-icon--dark">☀️</span>
				</button>
				<label for="nav-toggle" class="nav-hamburger" aria-label="Navigation öffnen/schließen">
					<span class="nav-hamburger__bar"></span>
					<span class="nav-hamburger__bar"></span>
					<span class="nav-hamburger__bar"></span>
				</label>
			</div>

			<ul class="nav__links" role="list">
				<li><a href="#hof" class="nav__link">Hof</a></li>
				<li><a href="#maschinen" class="nav__link">Maschinen</a></li>
				<li><a href="#ausbildung" class="nav__link">Ausbildung</a></li>
				<li><a href="#anfahrt" class="nav__link">Anfahrt</a></li>
				<li><a href="#contact" class="nav__link nav__link--cta">Kontakt</a></li>
			</ul>
		</div>
	</nav>

	<main id="hof-top">

		<!-- ===== HERO – Vollbild mit Gradient-Overlay ===== -->
		<section class="hero" aria-labelledby="hero-heading">
			<img
				class="hero__bg"
				src={asset("images/hof-panorama-sicht2-januar.webp")}
				alt="Göttl Hof im Winter – Panoramablick über Oberbubach"
				width="1600"
				height="900"
				fetchpriority="high"
			/>
			<div class="hero__gradient" aria-hidden="true"></div>
			<div class="hero__content">
				<div class="hero__content-inner">
					<p class="hero__eyebrow">Oberbubach 1a · Gemeinde Roßbach, Niederbayern</p>
					<h1 id="hero-heading">Göttl Hof –<br/>Milch, Felder<br/>&amp; Ausbildung</h1>
					<p class="hero__lead">
						Wir arbeiten hier als Familie, bilden jedes Jahr aus und helfen
						Nachbarn mit Technik und Erfahrung.
					</p>
					<div class="hero__actions">
						<a class="btn btn--gold" href="#contact">Kontakt aufnehmen</a>
						<a class="hero__link" href="#ausbildung">Ausbildung ab 1. August →</a>
					</div>
					<p class="hero__hint">Besuche bitte kurz vorher ankündigen – dann nehmen wir uns Zeit für euch.</p>
				</div>
			</div>
		</section>

		<!-- ===== MAIN PAGE CONTENT ===== -->
		<div class="page">

			<!-- ===== STATS – horizontale Leiste ===== -->
			<section class="stats" aria-label="Hofkennzahlen">
				{stats.map((item, i) => (
					<div class="stats__item">
						<span class="stats__icon" aria-hidden="true" set:html={statsIcons[i]} />
						<p class="stats__value">{item.value}</p>
						<p class="stats__label">{item.label}</p>
					</div>
				))}
			</section>

			<!-- ===== CORNERSTONES / HOF ===== -->
			<section class="cornerstones" id="hof" aria-labelledby="cornerstones-heading">
				<div class="cornerstones__text">
					<p class="eyebrow">Was uns ausmacht</p>
					<h2 id="cornerstones-heading">Zwei Standbeine,<br/>ein Betrieb</h2>
					<p>
						Wir stehen morgens mit den Kühen auf, helfen Nachbarn mit Maschinen, führen Buch über Felder und geben
						Erfahrung weiter. Ruhig, ehrlich, bodenständig.
					</p>
				</div>
				<div class="cornerstones__cards">
					{cornerstones.map((block) => (
						<article class="cornerstone-card">
							<h3>{block.title}</h3>
							<p>{block.description}</p>
							<ul class="cornerstone-card__list">
								{block.bullets.map((item) => (
									<li><span class="bullet-mark" aria-hidden="true">▪</span>{item}</li>
								))}
							</ul>
						</article>
					))}
				</div>
			</section>

			<!-- ===== EQUIPMENT / MASCHINEN ===== -->
			<section class="equipment" id="maschinen" aria-labelledby="equipment-heading">
				<div class="equipment__header">
					<p class="eyebrow">Technik aus Oberbubach</p>
					<h2 id="equipment-heading">Maschinen &amp; Leistungen</h2>
					<p class="equipment__sub">
						Moderne Technik hilft uns, zuverlässig zu liefern – auf den eigenen Flächen wie auch bei Nachbarn.
					</p>
				</div>
				<div class="equipment__grid">
					{equipment.map((card, i) => (
						<article class={`equip-card${i === 0 ? ' equip-card--featured' : ''}`}>
							<div class="equip-card__inner">
								<h3 class="equip-card__title">{card.title}</h3>
								<ul class="equip-card__list">
									{card.details.map((detail) => (
										<li><span class="bullet-mark" aria-hidden="true">▪</span>{detail}</li>
									))}
								</ul>
							</div>
						</article>
					))}
				</div>
			</section>

			<!-- ===== GALLERY ===== -->
			<section class="gallery" aria-label="Hof Impressionen">
				{gallery.map((shot) => (
					<figure class="gallery__item">
						<img
							src={shot.image}
							alt={shot.title}
							loading="lazy"
							width="480"
							height="360"
						/>
						<figcaption>{shot.title}</figcaption>
					</figure>
				))}
			</section>

			<!-- ===== SEASONS "Unser Jahr" ===== -->
			<section class="seasons" aria-labelledby="seasons-heading">
				<div class="seasons__intro">
					<p class="eyebrow">Der Rhythmus des Jahres</p>
					<h2 id="seasons-heading">Unser Jahr am Hof</h2>
					<p>Was wann passiert – ein Überblick über Feldarbeit, Stall und die besten Zeiten für einen Besuch.</p>
				</div>
				<div class="seasons__strip">
					{seasons.map((season, i) => (
						<article class="season-card" style={`--season-color: ${seasonMeta[i].color}`}>
							<div class="season-card__top">
								<span class="season-card__emoji" aria-hidden="true">{seasonMeta[i].emoji}</span>
								<span class="season-card__timeframe">{season.timeframe}</span>
							</div>
							<h3 class="season-card__title">{season.title}</h3>
							<ul class="season-card__list">
								{season.tasks.map((task) => (
									<li>{task}</li>
								))}
							</ul>
						</article>
					))}
				</div>
			</section>

			<!-- ===== TRAINING / AUSBILDUNG ===== -->
			<section class="training" id="ausbildung" aria-labelledby="training-heading">
				<div class="training__info">
					<p class="eyebrow">Ausbildung &amp; Mitarbeit</p>
					<h2 id="training-heading">Landwirtschaft<br/>wirklich lernen</h2>
					<p class="training__desc">
						Start ist jedes Jahr am <strong>1. August</strong>. Wir nehmen 1–2 Personen, die Landwirtschaft wirklich
						lernen wollen. Eigene Projekte, Umgang mit Tieren und Maschinen, Wohnen nach Absprache.
					</p>

					<div class="training__timeline" aria-label="Ausbildungsplätze">
						{trainingSlots.map((slot) => (
							<div class={`tslot tslot--${slot.status}`}>
								<div class="tslot__body">
									<span class="tslot__year">{slot.year}</span>
									<span class="tslot__note">{slot.note}</span>
									<span class="tslot__status-wrap">
										<span class="tslot__dot" aria-hidden="true"></span>
										<span class="tslot__status-text">{slot.status}</span>
									</span>
								</div>
							</div>
						))}
					</div>
				</div>

				<div class="training__visual">
					<img
						src={asset("images/kuh-mit-kalb.jpg")}
						alt="Kuh mit Kalb im Stall"
						loading="lazy"
						width="560"
						height="400"
						class="training__image"
					/>
					<div class="training__cta-box">
						<p>Sprich uns an, erzähl kurz wer du bist – wir melden uns fix.</p>
						<a class="btn btn--primary" href="#contact">Ausbildung anfragen</a>
					</div>
				</div>
			</section>

			<!-- ===== FAQ ===== -->
			<section class="faq" aria-labelledby="faq-heading">
				<div class="faq__head">
					<p class="eyebrow">Häufige Fragen</p>
					<h2 id="faq-heading">Fragen, die wir oft hören</h2>
				</div>
				<div class="faq__list">
					{faqs.map((item) => (
						<details class="faq__item">
							<summary class="faq__question">
								<span>{item.question}</span>
								<span class="faq__chevron" aria-hidden="true">+</span>
							</summary>
							<p class="faq__answer">{item.answer}</p>
						</details>
					))}
				</div>
			</section>

			<!-- ===== VISIT / ANFAHRT ===== -->
			<section class="visit" id="anfahrt" aria-labelledby="visit-heading">
				<div class="visit__info">
					<p class="eyebrow">So findet ihr uns</p>
					<h2 id="visit-heading">Anfahrt &amp; Besuch</h2>
					<ul class="visit__details">
						<li><span class="visit__icon">🏠</span><span>{visit.address}</span></li>
						<li><span class="visit__icon">📅</span><span>Bitte Besuch vorher ankündigen</span></li>
						<li><span class="visit__icon">🚗</span><span>Parken am Hof – bitte langsam anfahren</span></li>
						<li><span class="visit__icon">🗺️</span><span>Navigation: „Göttl Hof Oberbubach"</span></li>
					</ul>
					<div class="visit__actions">
						<a class="btn btn--primary" href={visit.mapsLink} target="_blank" rel="noreferrer">Google Maps Route</a>
					</div>
				</div>
				<div class="visit__map">
					<iframe
						src={visit.googleMaps}
						loading="lazy"
						title="Karte Oberbubach"
						allowfullscreen
						width="600"
						height="400"
					></iframe>
				</div>
			</section>

			<!-- ===== BLOG ===== -->
			<section class="blog" id="blog" aria-labelledby="blog-heading">
				<div class="blog__head">
					<p class="eyebrow">Vom Hof</p>
					<h2 id="blog-heading">Blog &amp; Aktuelles</h2>
				</div>
				<div class="blog__grid">
					{posts.map((post, i) => (
						<article class={`blog-card${i === 0 ? ' blog-card--featured' : ''}`}>
							<p class="blog-card__category">{post.category}</p>
							<h3 class="blog-card__title">{post.title}</h3>
							<p class="blog-card__meta">
								<time datetime={post.date}>{post.date}</time>&ensp;·&ensp;{post.readTime}
							</p>
							<p class="blog-card__summary">{post.summary}</p>
							<a class="blog-card__link" href={asset(`/blog/${post.slug}/`)}>Mehr lesen →</a>
						</article>
					))}
				</div>
			</section>

		</div><!-- end .page -->

		<!-- ===== CONTACT – volle Breite, grüner Bereich ===== -->
		<section class="contact" id="contact" aria-labelledby="contact-heading">
			<div class="contact__inner">
				<p class="contact__eyebrow">Direkt in Kontakt</p>
				<h2 id="contact-heading">Kontakt &amp; Rückfragen</h2>
				<p>Wir freuen uns über eure Nachricht – am besten erreichbar täglich zwischen 18 und 20 Uhr.</p>
				<div class="contact__buttons">
					<a class="btn btn--contact-primary" href="tel:+4985641268">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.82a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 15.92z"/></svg>
						Anrufen
					</a>
					<a class="btn btn--contact-outline" href="mailto:info@goettl-oberbubach.de">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
						Mail schreiben
					</a>
					<a class="btn btn--wa" href="https://wa.me/491605925821" target="_blank" rel="noreferrer">
						<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
						WhatsApp
					</a>
				</div>
			</div>
		</section>

	</main>

	<footer class="site-footer">
		<p>© {new Date().getFullYear()} Göttl Hof · Oberbubach 1a · 94439 Roßbach</p>
		<nav aria-label="Footer-Navigation">
			<a href="/impressum">Impressum</a>
			<a href="/datenschutz">Datenschutz</a>
		</nav>
	</footer>
</Layout>

<style>
/* ============================================================
   GLOBAL / RESET
   ============================================================ */
:global(html) {
	scroll-behavior: smooth;
}

@media (prefers-reduced-motion: reduce) {
	:global(html) { scroll-behavior: auto; }
	:global(*), :global(*::before), :global(*::after) {
		animation-duration: 0.01ms !important;
		animation-iteration-count: 1 !important;
		transition-duration: 0.01ms !important;
	}
}

:global(body) {
	margin: 0;
	background: var(--bg);
	color: var(--text);
	font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
	transition: background 0.3s, color 0.3s;
}

/* ============================================================
   FOCUS VISIBLE
   ============================================================ */
:global(:focus-visible) {
	outline: 3px solid var(--accent-gold);
	outline-offset: 3px;
	border-radius: 4px;
}

/* ============================================================
   DARK TOGGLE INSIDE NAV
   ============================================================ */
.nav__actions {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	order: 2;
}

.nav__dark-toggle {
	border: 1px solid var(--border);
	background: transparent;
	border-radius: 999px;
	padding: 0.35rem 0.75rem;
	min-height: 36px;
	font-size: 0.95rem;
	line-height: 1;
	color: var(--text);
	display: inline-flex;
	align-items: center;
	gap: 0.3rem;
	cursor: pointer;
	transition: background 0.2s, color 0.2s;
}

.nav__dark-toggle:hover { background: var(--bg-soft); }

.nav__dark-toggle .toggle-icon--dark { display: none; }
html.dark .nav__dark-toggle .toggle-icon--light { display: none; }
html.dark .nav__dark-toggle .toggle-icon--dark { display: inline; }

/* ============================================================
   STICKY NAVIGATION
   ============================================================ */
.site-nav {
	position: sticky;
	top: 0;
	z-index: 1000;
	background: color-mix(in srgb, var(--bg-card) 88%, transparent);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	border-bottom: 1px solid var(--border);
}

.nav__inner {
	display: flex;
	align-items: center;
	gap: 1rem;
	max-width: 1440px;
	margin: 0 auto;
	padding: 0 1.5rem;
	height: 64px;
}

.nav__brand {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	text-decoration: none;
	color: var(--text);
	font-family: "Playfair Display", serif;
	font-size: 1.15rem;
	font-weight: 600;
	white-space: nowrap;
	flex-shrink: 0;
}

.nav__brand-icon {
	width: 26px;
	height: 26px;
	display: block;
}

.nav__links {
	display: flex;
	align-items: center;
	gap: 0.25rem;
	list-style: none;
	margin-left: auto;
	padding: 0;
	order: 1;
}

.nav__link {
	display: inline-flex;
	align-items: center;
	padding: 0.5rem 0.75rem;
	min-height: 44px;
	text-decoration: none;
	color: var(--text-muted);
	font-size: 0.9rem;
	font-weight: 500;
	border-radius: 8px;
	transition: color 0.2s, background 0.2s;
	white-space: nowrap;
}
.nav__link:hover { color: var(--text); background: var(--bg-soft); }

.nav__link--cta {
	background: var(--accent);
	color: #fff !important;
	padding: 0.5rem 1rem;
	border-radius: 999px;
	font-weight: 600;
}
.nav__link--cta:hover { background: var(--accent-dark); }

.nav-toggle-input { display: none; }

.nav-hamburger {
	display: none;
	flex-direction: column;
	justify-content: center;
	gap: 5px;
	cursor: pointer;
	padding: 0.5rem;
	margin-left: auto;
	min-width: 44px; min-height: 44px;
	align-items: center;
	border-radius: 8px;
	transition: background 0.2s;
}
.nav-hamburger:hover { background: var(--bg-soft); }

.nav-hamburger__bar {
	display: block;
	width: 22px; height: 2px;
	background: var(--text);
	border-radius: 2px;
	transition: transform 0.3s, opacity 0.3s;
}

.nav-toggle-input:checked + .nav__actions .nav-hamburger__bar:nth-child(1) {
	transform: translateY(7px) rotate(45deg);
}
.nav-toggle-input:checked + .nav__actions .nav-hamburger__bar:nth-child(2) {
	opacity: 0;
}
.nav-toggle-input:checked + .nav__actions .nav-hamburger__bar:nth-child(3) {
	transform: translateY(-7px) rotate(-45deg);
}

/* ============================================================
   MAIN WRAPPER
   ============================================================ */
#hof-top {
	display: flex;
	flex-direction: column;
}

/* PAGE INNER – sectioned content with max-width */
.page {
	display: flex;
	flex-direction: column;
	gap: clamp(3rem, 6vw, 5rem);
	padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 4vw, 2.5rem);
	max-width: 1280px;
	width: 100%;
	margin: 0 auto;
	box-sizing: border-box;
}

.page section {
	scroll-margin-top: 80px;
}

/* Headings */
.page h1, .page h2, .page h3,
.hero__content h1,
.contact h2 {
	font-family: "Playfair Display", serif;
}

/* Eyebrow label */
.eyebrow {
	text-transform: uppercase;
	letter-spacing: 0.2em;
	font-size: 0.72rem;
	font-weight: 600;
	color: var(--accent);
	margin: 0 0 0.6rem;
}

/* Shared bullet mark */
.bullet-mark {
	color: var(--accent);
	margin-right: 0.45rem;
	font-size: 0.7rem;
	flex-shrink: 0;
}

/* ============================================================
   HERO – Vollbild Cinematic
   ============================================================ */
.hero {
	position: relative;
	min-height: 72vh;
	overflow: hidden;
	display: flex;
	align-items: flex-end;
	animation: heroFade 0.9s ease both;
}

@keyframes heroFade {
	from { opacity: 0; }
	to   { opacity: 1; }
}

.hero__bg {
	position: absolute;
	inset: 0;
	width: 100%;
	height: 100%;
	object-fit: cover;
	object-position: center 30%;
	display: block;
	z-index: 0;
}

.hero__gradient {
	position: absolute;
	inset: 0;
	background: linear-gradient(
		to top,
		rgba(20, 18, 12, 0.88) 0%,
		rgba(20, 18, 12, 0.4) 40%,
		transparent 65%
	);
	z-index: 1;
}

.hero__content {
	position: relative;
	z-index: 2;
	width: 100%;
	padding: 0;
}

.hero__content-inner {
	max-width: 1440px;
	margin: 0 auto;
	padding: clamp(2rem, 5vw, 4rem) clamp(1.5rem, 4vw, 3rem);
	padding-top: 0;
	max-width: 780px;
	margin: 0;
	padding-left: clamp(1.5rem, 5vw, 4rem);
	padding-right: clamp(1.5rem, 5vw, 4rem);
	padding-bottom: clamp(2.5rem, 5vw, 4rem);
}

.hero__eyebrow {
	text-transform: uppercase;
	letter-spacing: 0.22em;
	font-size: 0.72rem;
	font-weight: 600;
	color: var(--accent);
	margin: 0 0 0.75rem;
	/* Use a slightly lighter green for readability on dark bg */
	color: #7dcb70;
}

.hero__content h1 {
	font-size: clamp(2.5rem, 5.5vw, 4.5rem);
	line-height: 1.1;
	color: #fff;
	margin: 0 0 1.1rem;
	letter-spacing: -0.01em;
	text-shadow: 0 2px 20px rgba(0,0,0,0.3);
}

.hero__lead {
	font-size: clamp(1rem, 1.8vw, 1.15rem);
	line-height: 1.65;
	color: rgba(255, 255, 255, 0.82);
	max-width: 50ch;
	margin: 0 0 1.75rem;
}

.hero__actions {
	display: flex;
	flex-wrap: wrap;
	gap: 0.85rem;
	margin-bottom: 1.5rem;
}

.hero__link {
	display: inline-flex;
	align-items: center;
	min-height: 44px;
	color: rgba(255,255,255,0.85);
	font-weight: 600;
	font-size: 0.95rem;
	text-decoration: none;
	padding: 0.5rem 0;
	border-bottom: 1px solid rgba(255,255,255,0.4);
	transition: color 0.2s, border-color 0.2s;
}
.hero__link:hover {
	color: #fff;
	border-color: #fff;
}

.hero__hint {
	font-size: 0.82rem;
	color: rgba(255, 255, 255, 0.5);
	margin: 0;
	letter-spacing: 0.01em;
}

/* ============================================================
   SHARED BUTTONS
   ============================================================ */
.btn {
	display: inline-flex;
	justify-content: center;
	align-items: center;
	gap: 0.45rem;
	border-radius: 999px;
	padding: 0.75rem 1.6rem;
	min-height: 44px;
	font-size: 0.93rem;
	font-weight: 600;
	text-decoration: none;
	border: 2px solid transparent;
	cursor: pointer;
	transition: background 0.2s, color 0.2s, border-color 0.2s, transform 0.15s;
	white-space: nowrap;
}
.btn:hover { transform: translateY(-2px); }
.btn:active { transform: translateY(0); }

/* Gold primary – used on hero */
.btn--gold {
	background: var(--accent-gold);
	color: #1c1a15;
	border-color: var(--accent-gold);
}
.btn--gold:hover { background: color-mix(in srgb, var(--accent-gold) 85%, #000); }

/* Green primary – used elsewhere */
.btn--primary {
	background: var(--accent);
	color: #fff;
	border-color: var(--accent);
}
.btn--primary:hover { background: var(--accent-dark); border-color: var(--accent-dark); }

.btn--outline {
	background: transparent;
	color: var(--accent);
	border-color: var(--accent);
}
.btn--outline:hover { background: var(--accent); color: #fff; }

/* Contact section specific */
.btn--contact-primary {
	background: #fff;
	color: var(--accent-dark);
	border-color: #fff;
}
.btn--contact-primary:hover { background: rgba(255,255,255,0.9); }

.btn--contact-outline {
	background: transparent;
	color: #fff;
	border-color: rgba(255,255,255,0.6);
}
.btn--contact-outline:hover { background: rgba(255,255,255,0.12); border-color: #fff; }

.btn--wa {
	background: #25D366;
	color: #fff;
	border-color: #25D366;
}
.btn--wa:hover { background: #1ebe5d; border-color: #1ebe5d; }

/* ============================================================
   STATS – horizontale Leiste
   ============================================================ */
.stats {
	display: flex;
	flex-wrap: wrap;
	border: 1px solid var(--border);
	border-radius: 1.2rem;
	background: var(--bg-card);
	overflow: hidden;
}

.stats__item {
	flex: 1 1 140px;
	padding: clamp(1.2rem, 2.5vw, 1.8rem) clamp(1rem, 2vw, 2rem);
	display: flex;
	flex-direction: column;
	align-items: center;
	text-align: center;
	border-right: 1px solid var(--border);
}
.stats__item:last-child { border-right: none; }

.stats__icon {
	display: flex;
	align-items: center;
	justify-content: center;
	margin-bottom: 0.6rem;
	color: var(--accent);
	opacity: 0.85;
}

.stats__value {
	margin: 0 0 0.2rem;
	font-family: "Playfair Display", serif;
	font-size: clamp(1.9rem, 4vw, 3rem);
	font-weight: 600;
	line-height: 1;
	color: var(--text);
}

.stats__label {
	margin: 0;
	font-size: 0.82rem;
	color: var(--text-muted);
	letter-spacing: 0.04em;
}

/* ============================================================
   CORNERSTONES / HOF
   ============================================================ */
.cornerstones {
	display: flex;
	flex-direction: column;
	gap: clamp(1.5rem, 3vw, 2.5rem);
}

.cornerstones__text {
	max-width: 340px;
}

.cornerstones__text h2 {
	font-size: clamp(1.8rem, 4vw, 2.6rem);
	margin: 0 0 0.85rem;
	line-height: 1.15;
}

.cornerstones__text p {
	color: var(--text-muted);
	line-height: 1.7;
	margin: 0;
}

.cornerstones__cards {
	display: grid;
	grid-template-columns: 1fr;
	gap: 1rem;
}

.cornerstone-card {
	border-left: 3px solid var(--accent);
	padding: 1.25rem 1.25rem 1.25rem 1.5rem;
	background: var(--bg-card);
}

.cornerstone-card h3 {
	font-family: "Playfair Display", serif;
	font-size: 1.15rem;
	margin: 0 0 0.5rem;
}

.cornerstone-card p {
	color: var(--text-muted);
	line-height: 1.65;
	margin: 0 0 0.75rem;
	font-size: 0.93rem;
}

.cornerstone-card__list {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0.3rem;
}

.cornerstone-card__list li {
	display: flex;
	align-items: baseline;
	gap: 0.3rem;
	font-size: 0.88rem;
	color: var(--text-muted);
}

@media (min-width: 768px) {
	.cornerstones {
		display: grid;
		grid-template-columns: 300px 1fr;
		align-items: start;
		gap: 3rem;
	}
	.cornerstones__text { max-width: none; }
	.cornerstones__cards {
		grid-template-columns: 1fr 1fr;
	}
}

/* ============================================================
   EQUIPMENT / MASCHINEN
   ============================================================ */
.equipment {
	display: flex;
	flex-direction: column;
	gap: 1.75rem;
}

.equipment__header h2 {
	font-size: clamp(1.8rem, 4vw, 2.6rem);
	margin: 0 0 0.6rem;
	line-height: 1.15;
}

.equipment__sub {
	color: var(--text-muted);
	line-height: 1.7;
	max-width: 60ch;
	margin: 0;
}

.equipment__grid {
	display: grid;
	grid-template-columns: 1fr;
	gap: 1px;
	background: var(--border);
	border: 1px solid var(--border);
	border-radius: 1.2rem;
	overflow: hidden;
}

.equip-card {
	border-top: 3px solid var(--accent-gold);
	background: var(--bg-card);
}

.equip-card:nth-child(even) {
	background: var(--bg-soft);
}

.equip-card__inner {
	padding: 1.5rem 1.75rem;
}

.equip-card__title {
	font-family: "Playfair Display", serif;
	font-size: 1.15rem;
	margin: 0 0 0.75rem;
}

.equip-card__list {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0.35rem;
}

.equip-card__list li {
	display: flex;
	align-items: baseline;
	font-size: 0.9rem;
	color: var(--text-muted);
}

/* First card full-width with bigger treatment */
.equip-card--featured {
	border-top-color: var(--accent);
}

.equip-card--featured .equip-card__inner {
	padding: 2rem 2.25rem;
}

.equip-card--featured .equip-card__title {
	font-size: clamp(1.2rem, 2.5vw, 1.5rem);
}

@media (min-width: 640px) {
	.equipment__grid {
		grid-template-columns: repeat(2, 1fr);
	}
	.equip-card--featured {
		grid-column: 1 / -1;
	}
	.equip-card--featured .equip-card__inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 2rem;
		align-items: start;
	}
}

@media (min-width: 900px) {
	.equipment__grid {
		grid-template-columns: repeat(3, 1fr);
	}
	.equip-card--featured {
		grid-column: 1 / -1;
	}
}

/* ============================================================
   GALLERY
   ============================================================ */
.gallery {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 0.5rem;
}

.gallery__item {
	margin: 0;
	border-radius: 0.75rem;
	overflow: hidden;
	aspect-ratio: 4 / 3;
	position: relative;
}

.gallery__item img {
	width: 100%; height: 100%;
	object-fit: cover;
	display: block;
	transition: transform 0.45s ease;
}
.gallery__item:hover img { transform: scale(1.05); }

.gallery__item figcaption {
	position: absolute;
	bottom: 0; left: 0; right: 0;
	padding: 0.5rem 0.75rem;
	font-size: 0.78rem;
	color: rgba(255,255,255,0.9);
	background: linear-gradient(transparent, rgba(10,8,5,0.65));
}

@media (min-width: 480px) {
	.gallery { grid-template-columns: repeat(3, 1fr); }
}

/* ============================================================
   SEASONS – horizontaler Timeline-Strip
   ============================================================ */
.seasons {
	display: flex;
	flex-direction: column;
	gap: 1.5rem;
}

.seasons__intro h2 {
	font-size: clamp(1.8rem, 4vw, 2.6rem);
	margin: 0 0 0.6rem;
	line-height: 1.15;
}

.seasons__intro p {
	color: var(--text-muted);
	line-height: 1.7;
	max-width: 55ch;
	margin: 0;
}

.seasons__strip {
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 1px;
	background: var(--border);
	border: 1px solid var(--border);
	border-radius: 1.2rem;
	overflow: hidden;
}

.season-card {
	background: var(--bg-card);
	padding: 1.5rem;
	border-top: 4px solid var(--season-color);
}

.season-card__top {
	display: flex;
	align-items: center;
	justify-content: space-between;
	margin-bottom: 0.5rem;
}

.season-card__emoji {
	font-size: 1.4rem;
	line-height: 1;
}

.season-card__timeframe {
	font-size: 0.75rem;
	text-transform: uppercase;
	letter-spacing: 0.08em;
	color: var(--text-muted);
	font-weight: 500;
}

.season-card__title {
	font-family: "Playfair Display", serif;
	font-size: 1.1rem;
	margin: 0 0 0.75rem;
}

.season-card__list {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0.35rem;
}

.season-card__list li {
	font-size: 0.85rem;
	color: var(--text-muted);
	padding-left: 0.9rem;
	position: relative;
}

.season-card__list li::before {
	content: "–";
	position: absolute;
	left: 0;
	color: var(--season-color);
}

@media (min-width: 768px) {
	.seasons__strip {
		grid-template-columns: repeat(4, 1fr);
	}
}

/* ============================================================
   TRAINING / AUSBILDUNG – 50/50 Feature Layout
   ============================================================ */
.training {
	display: flex;
	flex-direction: column;
	gap: 2.5rem;
}

.training__info h2 {
	font-size: clamp(1.8rem, 4vw, 2.6rem);
	margin: 0 0 0.85rem;
	line-height: 1.15;
}

.training__desc {
	color: var(--text-muted);
	line-height: 1.7;
	margin: 0 0 2rem;
	max-width: 55ch;
}

/* Timeline */
.training__timeline {
	position: relative;
	padding-left: 2.25rem;
	display: flex;
	flex-direction: column;
	gap: 0;
}

.training__timeline::before {
	content: '';
	position: absolute;
	left: 0.5rem;
	top: 0.6rem;
	bottom: 0.6rem;
	width: 2px;
	background: var(--border);
}

.tslot {
	position: relative;
	padding: 0.8rem 0;
	border-bottom: 1px solid var(--border);
}
.tslot:last-child { border-bottom: none; }

.tslot::before {
	content: '';
	position: absolute;
	left: -1.75rem;
	top: 1.15rem;
	width: 10px; height: 10px;
	border-radius: 50%;
	background: var(--border);
	border: 2px solid var(--bg);
}

.tslot--frei::before {
	background: var(--accent);
}

.tslot__body {
	display: flex;
	align-items: center;
	gap: 0.75rem;
	flex-wrap: wrap;
}

.tslot__year {
	font-family: "Playfair Display", serif;
	font-size: 1.1rem;
	font-weight: 600;
	min-width: 3.5rem;
}

.tslot__note {
	font-size: 0.88rem;
	color: var(--text-muted);
	flex: 1;
}

.tslot__status-wrap {
	display: flex;
	align-items: center;
	gap: 0.35rem;
}

.tslot__dot {
	width: 7px; height: 7px;
	border-radius: 50%;
	background: var(--text-muted);
	flex-shrink: 0;
}
.tslot--frei .tslot__dot { background: var(--accent); }

.tslot__status-text {
	font-size: 0.8rem;
	font-weight: 600;
	text-transform: uppercase;
	letter-spacing: 0.1em;
	color: var(--text-muted);
}
.tslot--frei .tslot__status-text { color: var(--accent); }

/* Right side */
.training__visual {
	display: flex;
	flex-direction: column;
	gap: 1.25rem;
}

.training__image {
	width: 100%;
	aspect-ratio: 4 / 3;
	object-fit: cover;
	border-radius: 1rem;
	display: block;
}

.training__cta-box {
	padding: 1.25rem 1.5rem;
	background: var(--bg-strong);
	border-radius: 0.75rem;
}

.training__cta-box p {
	margin: 0 0 1rem;
	color: var(--text-muted);
	font-size: 0.93rem;
}

@media (min-width: 768px) {
	.training {
		display: grid;
		grid-template-columns: 1fr 1fr;
		align-items: start;
		gap: 3rem;
	}
}

/* ============================================================
   FAQ – Elegant Accordion
   ============================================================ */
.faq {
	display: grid;
	grid-template-columns: 1fr;
	gap: 2rem;
}

.faq__head h2 {
	font-size: clamp(1.8rem, 4vw, 2.6rem);
	margin: 0;
	line-height: 1.15;
}

.faq__list {
	display: flex;
	flex-direction: column;
}

.faq__item {
	border-bottom: 1px solid var(--border);
}
.faq__item:first-child { border-top: 1px solid var(--border); }

.faq__question {
	display: flex;
	align-items: center;
	justify-content: space-between;
	gap: 1.5rem;
	padding: 1.2rem 0;
	cursor: pointer;
	font-weight: 600;
	font-size: clamp(1rem, 2vw, 1.1rem);
	font-family: "Playfair Display", serif;
	list-style: none;
	min-height: 44px;
	transition: color 0.2s;
}
.faq__question::-webkit-details-marker { display: none; }
.faq__question:hover { color: var(--accent); }

.faq__chevron {
	flex-shrink: 0;
	font-size: 1.4rem;
	color: var(--accent);
	transition: transform 0.25s ease;
	font-weight: 300;
	line-height: 1;
}
.faq__item[open] .faq__chevron {
	transform: rotate(45deg);
}

.faq__answer {
	margin: 0;
	padding: 0 0 1.2rem;
