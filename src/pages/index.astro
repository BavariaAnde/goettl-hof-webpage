---
import Layout from "../layouts/Layout.astro";

const stats = [
	{ label: "Familienbetrieb seit", value: "1978" },
	{ label: "Milchkühe", value: "≈ 120" },
	{ label: "Hektar bewirtschaftet", value: "85 ha" },
	{ label: "Generationen im Team", value: "3" }
];

const services = [
	{
		title: "Milchvieh mit Herz",
		description:
			"Gesunde Herden, moderne Stalltechnik und viel Handarbeit – so entsteht täglich frische Milch vom Göttl Hof.",
		keypoints: ["Tierwohl im Fokus", "Weide- & Laufstall", "Eigene Futterkreisläufe"]
	},
	{
		title: "Ackerbau & Grünland",
		description:
			"Getreide, Kleegras und Mais aus Niederbayern: nachhaltig bewirtschaftet, bodenschonend gepflegt.",
		keypoints: ["Schonende Bodenbearbeitung", "Biodiversitätsstreifen", "Jährliche Fruchtfolge"]
	},
	{
		title: "Lohnarbeiten & Nachbarschaft",
		description:
			"Wir unterstützen Betriebe in der Region mit Maschinenleistung, Know-how und zuverlässigen Abläufen.",
		keypoints: ["Erntehilfe", "Ballentransport", "Digitale Ablage"]
	}
];

const gallery = [
	{
		title: "Morgenlicht am Stall",
		image: "https://images.unsplash.com/photo-1527489377706-5bf97e608852?auto=format&fit=crop&w=1200&q=80"
	},
	{
		title: "Grünland im Sommer",
		image: "https://images.unsplash.com/photo-1500937386664-56d1dfef3854?auto=format&fit=crop&w=1200&q=80"
	},
	{
		title: "Familie & Hofgemeinschaft",
		image: "https://images.unsplash.com/photo-1504593811423-6dd665756598?auto=format&fit=crop&w=1200&q=80"
	},
	{
		title: "Technik trifft Natur",
		image: "https://images.unsplash.com/photo-1469474968028-56623f02e42e?auto=format&fit=crop&w=1200&q=80"
	}
];

const posts = [
	{
		title: "Frische Silage & neue Saison",
		date: "März 2026",
		summary: "Wir starten mit viel Rückenwind in die Feldarbeit – bald mehr im Blog.",
		readingTime: "3 Min"
	},
	{
		title: "Ein Blick in den Melkstand",
		date: "Februar 2026",
		summary: "Tierwohl, Sensorik und Handarbeit – so läuft ein Morgen bei uns.",
		readingTime: "4 Min"
	},
	{
		title: "Nachbarschaftshilfe reloaded",
		date: "Januar 2026",
		summary: "Warum wir Maschinen teilen und welche Runden dieses Jahr anstehen.",
		readingTime: "5 Min"
	}
];
---
<Layout
	title="Göttl Hof – Familienbetrieb aus Niederbayern"
	description="Milchvieh, Felder und Zusammenhalt: Der Göttl Hof zeigt, wie moderner Familienbetrieb funktioniert."
>
	<main class="site">
		<section class="hero" id="home">
			<div class="hero__bg"></div>
			<div class="hero__content">
				<p class="hero__eyebrow">Milchvieh · Ackerbau · Familie</p>
				<h1>Göttl Hof Niederbayern</h1>
				<p class="hero__text">
					Familiengeführt in dritter Generation, verwurzelt in Niederbayern und offen für Neues.
					Wir verbinden traditionelle Landwirtschaft mit digitalen Abläufen – ehrlich, nahbar, nachhaltig.
				</p>
				<div class="hero__cta">
					<a class="btn btn--primary" href="#contact">Kontakt aufnehmen</a>
					<a class="btn btn--ghost" href="#about">Mehr über uns</a>
				</div>
			</div>
		</section>

		<section class="stats" aria-label="Kennzahlen">
			{stats.map((item) => (
				<div class="stat" aria-label={item.label}>
					<span>{item.value}</span>
					<p>{item.label}</p>
				</div>
			))}
		</section>

		<section class="section" id="about">
			<div class="section__header">
				<p class="eyebrow">Wofür wir stehen</p>
				<h2>Milchviehbetrieb mit Zukunft &amp; Heimatgefühl</h2>
				<p>
					Wir bewirtschaften Wiesen, Felder und Wälder im Herzen Niederbayerns, pflegen unsere Herde und
					arbeiten als Familie Hand in Hand. Technik unterstützt uns, ersetzt aber nicht den persönlichen Blick
					auf Tiere, Böden und Menschen.
				</p>
			</div>
			<div class="services">
				{services.map((service) => (
					<article class="service-card">
						<h3>{service.title}</h3>
						<p>{service.description}</p>
						<ul>
							{service.keypoints.map((point) => (
								<li>{point}</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</section>

		<section class="section section--gallery" id="impressions">
			<div class="section__header">
				<p class="eyebrow">Einblicke</p>
				<h2>Momente vom Hof (Platzhalter)</h2>
				<p>Die echten Fotos liefern wir nach – bis dahin sorgen hochwertige Platzhalter für das richtige Gefühl.</p>
			</div>
			<div class="gallery">
				{gallery.map((item) => (
					<figure>
						<img src={item.image} alt={item.title} loading="lazy" width="320" height="400" />
						<figcaption>{item.title}</figcaption>
					</figure>
				))}
			</div>
		</section>

		<section class="section" id="blog">
			<div class="section__header">
				<p class="eyebrow">Blog &amp; Neuigkeiten</p>
				<h2>Geschichten, sobald wir sie erzählen</h2>
				<p>
					Der Blog ist vorbereitet – sobald Texte und Fotos eintreffen, publizieren wir direkt über das neue
					CMS. Bis dahin zeigen wir, wie die Karten aussehen.
				</p>
			</div>
			<div class="post-grid">
				{posts.map((post) => (
					<article class="post-card">
						<p class="post-card__date">{post.date} · {post.readingTime}</p>
						<h3>{post.title}</h3>
						<p>{post.summary}</p>
						<button class="text-link" type="button">Beitrag folgt →</button>
					</article>
				))}
			</div>
		</section>

		<section class="contact" id="contact">
			<div class="contact__inner">
				<div class="contact__info">
					<p class="eyebrow">Kontakt</p>
					<h2>Schreib uns – wir melden uns fix</h2>
					<p>
						Göttl Hof · Niederbayern<br />
						Adresse &amp; genaue Daten folgen, sobald die finale Version online geht.
					</p>
					<ul>
						<li><strong>Mail:</strong> info@goettl-agrar.de (Placeholder)</li>
						<li><strong>Telefon:</strong> +49 (0) 000 000000 (wird ergänzt)</li>
					</ul>
				</div>
				<form class="contact__form">
					<label>
						Name
						<input type="text" name="name" placeholder="Dein Name" />
					</label>
					<label>
						E-Mail
						<input type="email" name="email" placeholder="dein@mail.de" />
					</label>
					<label>
						Nachricht
						<textarea name="message" rows="4" placeholder="Wie können wir helfen?"></textarea>
					</label>
					<button class="btn btn--primary" type="button">Formular folgt</button>
				</form>
			</div>
		</section>
	</main>
</Layout>

<style>
	:global(body) {
		background: radial-gradient(circle at top right, rgba(58, 141, 96, 0.08), transparent 55%),
			var(--bg-soft);
		color: #1b1b17;
	}

	.site {
		display: flex;
		flex-direction: column;
		gap: 5rem;
		padding: 2rem clamp(1.5rem, 4vw, 5rem) 5rem;
	}

	.hero {
		position: relative;
		border-radius: 2rem;
		padding: clamp(3rem, 8vw, 6rem);
		overflow: hidden;
		background: linear-gradient(135deg, #fefbf6 0%, #f1ebe0 60%, #e2efe6 100%);
	}

	.hero__bg {
		position: absolute;
		top: -10%;
		right: -10%;
		width: 55%;
		height: 120%;
		background: radial-gradient(circle, rgba(33, 94, 61, 0.25), transparent 60%);
		filter: blur(10px);
		animation: drift 14s ease-in-out infinite alternate;
	}

	.hero__content {
		position: relative;
		max-width: 780px;
		z-index: 1;
	}

	.hero__eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.3em;
		font-size: 0.8rem;
		color: var(--accent);
		margin-bottom: 1rem;
	}

	h1 {
		font-family: "Playfair Display", "Times New Roman", serif;
		font-size: clamp(2.5rem, 5vw, 4.8rem);
		color: #1c3023;
		margin: 0 0 1rem;
	}

	.hero__text {
		font-size: 1.15rem;
		line-height: 1.8;
		max-width: 48ch;
		color: var(--text-muted);
	}

	.hero__cta {
		margin-top: 2rem;
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.btn {
		border-radius: 999px;
		padding: 0.85rem 1.8rem;
		font-weight: 600;
		font-size: 1rem;
		border: 1px solid transparent;
		cursor: pointer;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
		text-decoration: none;
	}

	.btn--primary {
		background: var(--accent);
		color: #fff;
		box-shadow: 0 15px 30px rgba(33, 94, 61, 0.2);
	}

	.btn--ghost {
		border-color: rgba(33, 94, 61, 0.4);
		color: var(--accent);
		background: transparent;
	}

	.btn:hover {
		transform: translateY(-3px);
		box-shadow: 0 20px 40px rgba(33, 94, 61, 0.18);
	}

	.stats {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		gap: 1rem;
	}

	.stat {
		background: #fff;
		padding: 1.5rem;
		border-radius: 1.5rem;
		box-shadow: 0 20px 40px rgba(23, 34, 26, 0.08);
		text-align: center;
	}

	.stat span {
		display: block;
		font-size: 2rem;
		font-weight: 600;
		color: var(--accent);
	}

	.section {
		background: #fff;
		border-radius: 2rem;
		padding: clamp(2rem, 5vw, 4rem);
		box-shadow: 0 30px 60px rgba(21, 30, 24, 0.08);
		position: relative;
	}

	.section::after {
		content: "";
		position: absolute;
		inset: 10px;
		border-radius: 1.6rem;
		border: 1px solid rgba(33, 94, 61, 0.08);
		pointer-events: none;
	}

	.section__header {
		max-width: 720px;
		margin-bottom: 2rem;
	}

	.eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--accent);
		font-size: 0.8rem;
		margin-bottom: 0.7rem;
	}

	h2 {
		font-size: clamp(2rem, 4vw, 3rem);
		margin: 0 0 1rem;
		color: #1c271f;
	}

	.services {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1.5rem;
	}

	.service-card {
		background: var(--bg-strong);
		padding: 1.5rem;
		border-radius: 1.5rem;
		border: 1px solid rgba(33, 94, 61, 0.12);
		min-height: 280px;
	}

	.service-card h3 {
		margin-top: 0;
		color: var(--accent);
	}

	.service-card ul {
		padding-left: 1.2rem;
		color: var(--text-muted);
	}

	.section--gallery {
		background: var(--bg-strong);
	}

	.gallery {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.gallery figure {
		margin: 0;
		border-radius: 1.5rem;
		overflow: hidden;
		position: relative;
		background: #000;
	}

	.gallery img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.6s ease;
	}

	.gallery figure:hover img {
		transform: scale(1.06);
	}

	.gallery figcaption {
		position: absolute;
		bottom: 0;
		left: 0;
		right: 0;
		padding: 1rem;
		color: #fff;
		background: linear-gradient(180deg, transparent, rgba(0, 0, 0, 0.65));
		font-weight: 500;
	}

	.post-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 1.25rem;
	}

	.post-card {
		background: var(--bg-strong);
		padding: 1.5rem;
		border-radius: 1.5rem;
		border: 1px solid rgba(33, 94, 61, 0.08);
	}

	.post-card__date {
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--text-muted);
	}

	.text-link {
		background: transparent;
		border: none;
		color: var(--accent-light);
		font-weight: 600;
		cursor: pointer;
		padding: 0;
	}

	.contact {
		background: linear-gradient(135deg, #1f5e3c, #103822);
		border-radius: 2rem;
		color: #fff;
	}

	.contact__inner {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 2rem;
		padding: clamp(2rem, 4vw, 4rem);
	}

	.contact__info ul {
		list-style: none;
		padding: 0;
		margin: 1rem 0 0;
		line-height: 1.8;
	}

	.contact__form {
		background: rgba(255, 255, 255, 0.08);
		padding: 2rem;
		border-radius: 1.5rem;
		backdrop-filter: blur(6px);
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.contact__form label {
		display: flex;
		flex-direction: column;
		font-weight: 500;
		gap: 0.3rem;
	}

	.contact__form input,
	.contact__form textarea {
		border-radius: 0.8rem;
		border: none;
		padding: 0.9rem 1rem;
		font-size: 1rem;
		font-family: inherit;
	}

	.contact__form input:focus,
	.contact__form textarea:focus {
		outline: 2px solid rgba(255, 255, 255, 0.7);
	}

	@keyframes drift {
		0% {
			transform: translate(0, 0) scale(1);
		}
		100% {
			transform: translate(10%, -5%) scale(1.1);
		}
	}

	@media (max-width: 720px) {
		.site {
			padding-bottom: 3rem;
		}

		.hero__cta {
			flex-direction: column;
		}

		.section::after {
			display: none;
		}
	}
</style>
