---
import Layout from "../../layouts/Layout.astro";
import { blogPosts } from "../../data/blogPosts";
import Nav from "../../components/Nav.astro";

const baseUrl = (import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
const asset = (path: string) => `${baseUrl}/${path.replace(/^\/+/ , "")}`;
const publishedPosts = blogPosts.filter((post) => !/entwurf/i.test(post.status ?? ""));
---
<Layout title="Blog & Aktuelles – Göttl Hof" description="Aktuelle Themen rund um Hofleben, Ausbildung und Maschinen.">
	<Nav />
	<section class="blog-page" data-animate="fade">
		<header class="blog-page__head" data-animate="fade">
			<p class="eyebrow">Aktuelles</p>
			<h1>Blog &amp; Einblicke</h1>
			<p>Kurze Updates aus Oberbubach – zum Hofleben, zur Ausbildung und zur Technik, mit der wir arbeiten.</p>
		</header>

		<div class="blog-page__grid" data-animate="fade">
			{publishedPosts.map((post) => (
				<article class="blog-card" data-animate="fade">
					<a
						class="blog-card__link"
						href={asset(`/blog/${post.slug}/`)}
						aria-label={`${post.title} öffnen`}
						data-umami-event={`blog-${post.slug}`}
					>
						<img
							class="blog-card__image"
							src={asset(post.heroImage)}
							alt={post.heroAlt}
							loading="lazy"
							decoding="async"
							width="1200"
							height="675"
						/>
						<div class="blog-card__body">
							<p class="blog-card__category">{post.category}</p>
							<h2 class="blog-card__title">{post.title}</h2>
							<p class="blog-card__meta">
								{post.date} · {post.readTime} · {post.status}
							</p>
							<p class="blog-card__summary">{post.summary}</p>
							<span class="blog-card__cta" aria-hidden="true">Mehr lesen →</span>
						</div>
					</a>
				</article>
			))}
		</div>
	</section>

	<style>
	.blog-page {
		max-width: 1100px;
		margin: 0 auto;
		padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem);
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.blog-page__head h1 {
		font-family: "Playfair Display", serif;
		margin: 0.2rem 0 0.8rem;
	}

	.blog-page__head p {
		color: var(--text-muted);
		max-width: 55ch;
	}

	.blog-page__grid {
		display: grid;
		gap: clamp(1rem, 2vw, 1.5rem);
	}

	.blog-card {
		background: var(--bg-card);
		border-radius: 1.2rem;
		border: 1px solid var(--border);
		overflow: hidden;
		display: flex;
		flex-direction: column;
		gap: 0;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.blog-card:nth-child(even) {
		background: var(--bg-card);
	}

	.blog-card__image {
		width: 100%;
		height: 220px;
		object-fit: cover;
		object-position: center;
		background: linear-gradient(135deg, #e2ecd5 0%, #f6f1e7 100%);
		display: block;
	}

	.blog-card__body {
		padding: 1.1rem 1.35rem 1.35rem;
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		min-height: 190px;
	}

	.blog-card__category {
		text-transform: uppercase;
		font-size: 0.68rem;
		letter-spacing: 0.18em;
		color: var(--accent);
		font-weight: 600;
		margin: 0;
	}

	.blog-card__title {
		font-family: "Playfair Display", serif;
		margin: 0;
		line-height: 1.25;
		font-size: clamp(1.05rem, 1.7vw, 1.35rem);
	}

	.blog-card__meta {
		font-size: 0.8rem;
		color: var(--text-muted);
		margin: 0;
	}

	.blog-card__summary {
		color: var(--text-muted);
		line-height: 1.6;
		margin: 0.2rem 0 0.6rem;
		font-size: 0.9rem;
	}

	.blog-card__link {
		display: flex;
		flex-direction: column;
		color: inherit;
		text-decoration: none;
		height: 100%;
	}

	.blog-card__link:focus-visible {
		outline: 3px solid var(--accent-gold);
		outline-offset: 3px;
		border-radius: 1.2rem;
	}

	.blog-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 12px 28px var(--shadow);
	}

	.blog-card__cta {
		color: var(--accent);
		font-size: 0.88rem;
		font-weight: 600;
	}

	@media (min-width: 640px) {
		.blog-page__grid {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}

	@media (min-width: 1000px) {
		.blog-page__grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}
	</style>
</Layout>
