---
import Layout from "../../layouts/Layout.astro";
import { blogPosts } from "../../data/blogPosts";
import Nav from "../../components/Nav.astro";

const baseUrl = (import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
const asset = (path: string) => `${baseUrl}/${path.replace(/^\/+/ , "")}`;
const publishedPosts = blogPosts.filter((entry) => !/entwurf/i.test(entry.status ?? ""));

const { slug } = Astro.params;
const post = publishedPosts.find((entry) => entry.slug === slug);

export function getStaticPaths() {
	const published = blogPosts.filter((post) => !/entwurf/i.test(post.status ?? ""));
	return published.map((post) => ({ params: { slug: post.slug } }));
}

if (!post) {
	return Astro.redirect("/blog");
}
---
<Layout title={`${post.title} – Göttl Hof`} description={post.summary}>
	<Nav />
	<article class="blog-post">
		<div class="blog-post__hero">
			<p class="blog-post__category">{post.category}</p>
			<h1>{post.title}</h1>
			<p class="blog-post__meta">
				<span>{post.date}</span> · <span>{post.readTime}</span>
				{post.status && <span class="blog-post__status">{post.status}</span>}
			</p>
			<div class="blog-post__hero-image" style={`--blog-post-image: url(${asset(post.heroImage)})`} role="img" aria-label={post.heroAlt}></div>
		</div>

		<div class="blog-post__body">
			{post.content.map((section) => (
				<section>
					{section.heading && <h2>{section.heading}</h2>}
					{section.paragraphs.map((paragraph) => (
						<p>{paragraph}</p>
					))}
					{section.list && (
						<ul>
							{section.list.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					)}
				</section>
			))}
		</div>

		{post.cta && (
			<div class="blog-post__cta">
				<a class="btn btn--primary" href={asset(post.cta.href)} data-umami-event={`cta-${post.slug}`}>{post.cta.label}</a>
			</div>
		)}
	</article>

	<section class="blog-post__back">
		<a class="blog-post__backlink" href={asset("/blog/")}>
			← Zurück zur Übersicht
		</a>
	</section>

	<style>
	.blog-post {
		max-width: 840px;
		margin: 0 auto;
		padding: clamp(2rem, 4vw, 3rem) clamp(1rem, 4vw, 1.5rem);
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.blog-post__hero h1 {
		font-family: "Playfair Display", serif;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0.4rem 0 0.2rem;
	}

	.blog-post__category {
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-size: 0.65rem;
		color: var(--accent);
		margin: 0;
	}

	.blog-post__meta {
		color: var(--text-muted);
		font-size: 0.9rem;
		margin: 0 0 1.5rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.blog-post__status {
		background: var(--bg-soft);
		padding: 0.15rem 0.6rem;
		border-radius: 999px;
		text-transform: uppercase;
		font-size: 0.75rem;
		letter-spacing: 0.08em;
	}

	.blog-post__hero-image {
		width: 100%;
		border-radius: 1.2rem;
		aspect-ratio: 16 / 9;
		background-image: var(--blog-post-image, none), linear-gradient(135deg, #e2ecd5 0%, #f6f1e7 100%);
		background-size: cover;
		background-position: center;
		border: 1px solid var(--border);
		box-shadow: inset 0 0 0 1px rgba(255,255,255,0.4);
	}

	.blog-post__body section {
		margin-bottom: 2rem;
	}

	.blog-post__body h2 {
		font-family: "Playfair Display", serif;
		font-size: 1.4rem;
		margin-bottom: 0.75rem;
	}

	.blog-post__body p {
		line-height: 1.8;
		color: var(--text-muted);
		margin: 0 0 1rem;
	}

	.blog-post__body ul {
		list-style: disc;
		padding-left: 1.5rem;
		margin: 0 0 1.2rem;
		color: var(--text-muted);
	}

	.blog-post__cta {
		text-align: center;
	}

	.blog-post__back {
		text-align: center;
		padding-bottom: 3rem;
	}

	.blog-post__backlink {
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
	}

	.blog-post__backlink:hover {
		color: var(--accent-dark);
	}
	</style>
</Layout>
