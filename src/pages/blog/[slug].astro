---
import Layout from "../../layouts/Layout.astro";
import { blogPosts } from "../../data/blogPosts";
import Nav from "../../components/Nav.astro";

const baseUrl = (import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
const asset = (path: string) => `${baseUrl}/${path.replace(/^\/+/ , "")}`;
const publishedPosts = blogPosts.filter((entry) => !/entwurf/i.test(entry.status ?? ""));

const { slug } = Astro.params;
const post = publishedPosts.find((entry) => entry.slug === slug);

export function getStaticPaths() {
	const published = blogPosts.filter((post) => !/entwurf/i.test(post.status ?? ""));
	return published.map((post) => ({ params: { slug: post.slug } }));
}

if (!post) {
	return Astro.redirect("/blog");
}
---
<Layout
	title={`${post.title} – Göttl Hof`}
	description={post.summary}
	preloadImage={asset(post.heroImage)}
	preloadImageType="image/webp"
	preloadImageSizes="100vw"
>
	<Nav />
	<article class="blog-post" data-animate="fade">
		<div class="blog-post__hero">
			<p class="blog-post__category">{post.category}</p>
			<h1>{post.title}</h1>
			<p class="blog-post__meta">
				<span>{post.date}</span> · <span>{post.readTime}</span>
				{post.status && <span class="blog-post__status">{post.status}</span>}
			</p>
			<img
				class="blog-post__hero-image"
				src={asset(post.heroImage)}
				alt={post.heroAlt}
				width="1600"
				height="900"
				sizes="(min-width: 900px) 680px, 100vw"
				loading="eager"
				decoding="async"
				fetchpriority="high"
			/>
		</div>

		<div class="blog-post__body">
			{post.content.map((section) => (
				<section data-animate="fade">
					{section.heading && <h2>{section.heading}</h2>}
					{section.paragraphs.map((paragraph) => (
						<p>{paragraph}</p>
					))}
					{section.list && (
						<ul>
							{section.list.map((item) => (
								<li>{item}</li>
							))}
						</ul>
					)}
				</section>
			))}
		</div>

	{post.cta && (
		<div class="blog-post__cta" data-animate="fade">
			<a class="btn btn--primary" href={asset(post.cta.href)} data-umami-event={`blog:cta:${post.slug}`}>{post.cta.label}</a>
		</div>
	)}
	</article>

	<section class="blog-post__back" data-animate="fade">
		<a class="blog-post__backlink" href={asset("/blog/")}>
			← Zurück zur Übersicht
		</a>
	</section>

	<style>
	.blog-post {
		max-width: 840px;
		margin: 0 auto;
		padding: clamp(2rem, 4vw, 3rem) clamp(1rem, 4vw, 1.5rem);
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.blog-post__hero {
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.blog-post__hero h1 {
		font-family: "Playfair Display", serif;
		font-size: clamp(2rem, 5vw, 3rem);
		margin: 0.4rem 0 0.2rem;
	}

	.blog-post__category {
		text-transform: uppercase;
		letter-spacing: 0.18em;
		font-size: 0.65rem;
		color: var(--accent);
		margin: 0;
	}

	.blog-post__meta {
		color: var(--text-muted);
		font-size: 0.9rem;
		margin: 0 0 1.5rem;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
	}

	.blog-post__status {
		background: var(--bg-soft);
		padding: 0.15rem 0.6rem;
		border-radius: 999px;
		text-transform: uppercase;
		font-size: 0.75rem;
		letter-spacing: 0.08em;
	}

	.blog-post__hero-image {
		width: 100%;
		max-width: 620px;
		margin: 0.35rem auto 0;
		border-radius: 1.2rem;
		max-height: 400px;
		object-fit: cover;
		object-position: center;
		background: var(--bg-strong);
		border: 1px solid var(--border);
		box-shadow: 0 12px 26px var(--shadow), inset 0 0 0 1px rgba(255,255,255,0.4);
		display: block;
	}

	.blog-post__body section {
		margin-bottom: 2rem;
	}

	.blog-post__body h2 {
		font-family: "Playfair Display", serif;
		font-size: 1.4rem;
		margin-bottom: 0.75rem;
	}

	.blog-post__body p {
		line-height: 1.8;
		color: var(--text-muted);
		margin: 0 0 1rem;
	}

	.blog-post__body ul {
		list-style: disc;
		padding-left: 1.5rem;
		margin: 0 0 1.2rem;
		color: var(--text-muted);
	}

	.blog-post__cta {
		text-align: center;
	}

	.blog-post__back {
		text-align: center;
		padding-bottom: 3rem;
	}

	.blog-post__backlink {
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
	}

	.blog-post__backlink:hover {
		color: var(--accent-dark);
	}

	@media (min-width: 900px) {
		.blog-post {
			max-width: 980px;
		}

		.blog-post__hero h1 {
			font-size: clamp(2.2rem, 3.4vw, 3.2rem);
		}

		.blog-post__body {
			max-width: 72ch;
		}
	}

	@media (min-width: 1200px) {
		.blog-post__hero-image {
			max-width: 720px;
		}
	}
	@media (max-width: 767px) {
		.blog-post__hero-image {
			max-height: 250px;
		}
	}	</style>
</Layout>
