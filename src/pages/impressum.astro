<style>
	.imprint-page {
		max-width: 720px;
		margin: 0 auto;
		padding: clamp(2rem, 5vw, 4rem) clamp(1rem, 4vw, 2rem);
		color: var(--text);
	}

	.back-link {
		display: inline-block;
		margin-bottom: 2rem;
		color: var(--accent);
		text-decoration: none;
		font-weight: 500;
	}

	.back-link:hover {
		text-decoration: underline;
	}

	h1 {
		font-family: "Playfair Display", serif;
		font-size: clamp(2rem, 5vw, 3rem);
		margin-bottom: 2rem;
		color: var(--text);
	}

	h2 {
		font-family: "Playfair Display", serif;
		font-size: 1.25rem;
		margin-top: 2rem;
		margin-bottom: 0.5rem;
		color: var(--accent);
	}

	section {
		border-bottom: 1px solid var(--border);
		padding-bottom: 1.5rem;
		margin-bottom: 1.5rem;
	}

	section:last-child {
		border-bottom: none;
	}

	p {
		line-height: 1.75;
		color: var(--text-muted);
	}

	a {
		color: var(--accent);
		text-decoration: none;
	}

	a:hover {
		text-decoration: underline;
	}
</style>
