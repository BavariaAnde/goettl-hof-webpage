---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Göttl Hof",
	description = "Familienbetrieb aus Niederbayern mit Milchvieh, Feldern und Herz."
} = Astro.props as Props;
const siteUrl = "https://www.goettl-oberbubach.de";
const shareImage = `${siteUrl}/images/hof-panorama-sommer.webp`;
---
<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={siteUrl} />
		<meta property="og:site_name" content="Göttl Hof" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:image" content={shareImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={shareImage} />
		<link
			rel="preconnect"
			href="https://fonts.googleapis.com"
		/>
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
			<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Farm",
			"name": "Göttl Hof",
			"url": siteUrl,
			"image": shareImage,
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Oberbubach",
				"postalCode": "94439",
				"addressLocality": "Roßbach",
				"addressCountry": "DE"
			},
			"contactPoint": [{
				"@type": "ContactPoint",
				"contactType": "customer service",
				"telephone": "+4985641268",
				"email": "info@goettl-oberbubach.de"
			}]
		})}</script>
</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		color: #1f1d1a;
		background-color: #fdfaf4;
		--bg-soft: #fefbf6;
		--bg-strong: #f3efe7;
		--accent: #215e3d;
		--accent-light: #3a8d60;
		--accent-muted: rgba(33, 94, 61, 0.1);
		--text-muted: #5f5b52;
	}

	html,
	body {
		margin: 0;
		background: var(--bg-soft);
	}

	body {
		min-height: 100vh;
	}

	::selection {
		background: var(--accent);
		color: #fff;
	}
</style>
