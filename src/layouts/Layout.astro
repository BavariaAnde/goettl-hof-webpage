---
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Göttl Hof",
	description = "Familienbetrieb aus Niederbayern mit Milchvieh, Feldern und Herz."
} = Astro.props as Props;
const siteUrl = "https://www.goettl-oberbubach.de";
const shareImage = `${siteUrl}/images/hof-panorama-sommer.webp`;
---
<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={siteUrl} />
		<meta property="og:site_name" content="Göttl Hof" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:image" content={shareImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={shareImage} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@500;600&family=Inter:wght@400;500;600&display=swap"
			rel="stylesheet"
		/>
		<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Farm",
			"name": "Göttl Hof",
			"url": siteUrl,
			"image": shareImage,
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Oberbubach",
				"postalCode": "94439",
				"addressLocality": "Roßbach",
				"addressCountry": "DE"
			},
			"contactPoint": [{
				"@type": "ContactPoint",
				"contactType": "customer service",
				"telephone": "+4985641268",
				"email": "info@goettl-oberbubach.de"
			}]
		})}</script>
		<!-- Dark mode: apply before render to avoid flash -->
		<script is:inline>
			(function() {
				const saved = localStorage.getItem('darkMode');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (saved === 'true' || (saved === null && prefersDark)) {
					document.documentElement.classList.add('dark');
				}
			})();
		</script>
	</head>
	<body>
		<!-- Dark mode toggle button -->
		<button id="darkToggle" aria-label="Dark Mode umschalten" title="Dark Mode umschalten">
			<span class="toggle-icon toggle-icon--light">🌙</span>
			<span class="toggle-icon toggle-icon--dark">☀️</span>
		</button>
		<slot />
		<script>
			const btn = document.getElementById('darkToggle');
			btn?.addEventListener('click', () => {
				const isDark = document.documentElement.classList.toggle('dark');
				localStorage.setItem('darkMode', String(isDark));
			});
		</script>
	</body>
</html>

<style>
	:root {
		font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

		/* Light mode tokens */
		--bg:          #faf7f1;
		--bg-card:     #ffffff;
		--bg-soft:     #f5f0e8;
		--bg-strong:   #ede6d6;
		--border:      #ddd3be;
		--text:        #1c1a15;
		--text-muted:  #5f5b52;
		--accent:      #3a6b35;
		--accent-dark: #2a5228;
		--accent-gold: #c79a3a;
		--accent-light:#e8f4e4;
		--shadow:      rgba(20,18,12,0.08);
	}

	html.dark {
		/* Dark mode tokens */
		--bg:          #161410;
		--bg-card:     #201e18;
		--bg-soft:     #1d1b14;
		--bg-strong:   #252219;
		--border:      #3a3626;
		--text:        #f0ead8;
		--text-muted:  #a09880;
		--accent:      #5dab55;
		--accent-dark: #4a9342;
		--accent-gold: #d4a94a;
		--accent-light:#1e2f1c;
		--shadow:      rgba(0,0,0,0.35);
	}

	html, body {
		margin: 0;
		background: var(--bg);
		color: var(--text);
		transition: background 0.3s, color 0.3s;
	}

	body {
		min-height: 100vh;
	}

	::selection {
		background: var(--accent);
		color: #fff;
	}

	/* Dark mode toggle button */
	#darkToggle {
		position: fixed;
		top: 1rem;
		right: 1rem;
		z-index: 999;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 999px;
		padding: 0.45rem 0.9rem;
		cursor: pointer;
		font-size: 1.1rem;
		box-shadow: 0 2px 10px var(--shadow);
		transition: background 0.3s, border-color 0.3s;
		line-height: 1;
	}

	#darkToggle:hover {
		background: var(--bg-soft);
	}

	/* Show moon in light mode, sun in dark mode */
	.toggle-icon--dark { display: none; }
	html.dark .toggle-icon--light { display: none; }
	html.dark .toggle-icon--dark  { display: inline; }
</style>
