---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/playfair-display/500.css";
import "@fontsource/playfair-display/600.css";
interface Props {
	title?: string;
	description?: string;
}

const {
	title = "Göttl Hof",
	description = "Familienbetrieb aus Niederbayern mit Milchvieh, Feldern und Herz."
} = Astro.props as Props;
const siteUrl = "https://www.goettl-oberbubach.de";
const shareImage = `${siteUrl}/images/hof-panorama-sommer.webp`;
---
<!doctype html>
<html lang="de">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={siteUrl} />
		<meta property="og:site_name" content="Göttl Hof" />
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={siteUrl} />
		<meta property="og:image" content={shareImage} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={shareImage} />

		<!-- Umami Analytics -->
		<script defer src="https://umami.andreas-goettl.de/script.js" data-website-id="bb33e9e8-6b5d-45f7-8d3d-4d5b6983e80e"></script>

		<script type="application/ld+json">{JSON.stringify({
			"@context": "https://schema.org",
			"@type": "Farm",
			"name": "Göttl Hof",
			"url": siteUrl,
			"image": shareImage,
			"address": {
				"@type": "PostalAddress",
				"streetAddress": "Oberbubach 1a",
				"postalCode": "94439",
				"addressLocality": "Roßbach",
				"addressCountry": "DE"
			},
			"contactPoint": [{
				"@type": "ContactPoint",
				"contactType": "customer service",
				"telephone": "+4985641268",
				"email": "info@goettl-oberbubach.de"
			}]
		})}</script>
		<!-- Dark mode: apply before render to avoid flash -->
		<script is:inline>
			(function() {
				const saved = localStorage.getItem('darkMode');
				const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
				if (saved === 'true' || (saved === null && prefersDark)) {
					document.documentElement.classList.add('dark');
				}
			})();
		</script>
	</head>
	<body>
		<slot />
		<script>
			const btn = document.getElementById('darkToggle');
			btn?.addEventListener('click', () => {
				const isDark = document.documentElement.classList.toggle('dark');
				localStorage.setItem('darkMode', String(isDark));
			});
		</script>
		<!-- Umami Analytics: nach Setup ersetzen mit:
		<script defer src="https://stats.DEINE-DOMAIN/script.js" data-website-id="DEINE-WEBSITE-ID"></script>
		-->
	</body>
</html>

<style>
	:root {
		font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;

		/* Light mode tokens */
		--bg:          #faf7f1;
		--bg-card:     #ffffff;
		--bg-soft:     #f5f0e8;
		--bg-strong:   #ede6d6;
		--border:      #ddd3be;
		--text:        #1c1a15;
		--text-muted:  #5f5b52;
		--accent:      #3a6b35;
		--accent-dark: #2a5228;
		--accent-gold: #c79a3a;
		--accent-light:#e8f4e4;
		--shadow:      rgba(20,18,12,0.08);
	}

	html.dark {
		/* Dark mode tokens */
		--bg:          #161410;
		--bg-card:     #201e18;
		--bg-soft:     #1d1b14;
		--bg-strong:   #252219;
		--border:      #3a3626;
		--text:        #f0ead8;
		--text-muted:  #a09880;
		--accent:      #5dab55;
		--accent-dark: #4a9342;
		--accent-gold: #d4a94a;
		--accent-light:#1e2f1c;
		--shadow:      rgba(0,0,0,0.35);
	}

	html, body {
		margin: 0;
		background: var(--bg);
		color: var(--text);
		transition: background 0.3s, color 0.3s;
	}

	body {
		min-height: 100vh;
	}

	::selection {
		background: var(--accent);
		color: #fff;
	}

	/* Show moon in light mode, sun in dark mode */
	.toggle-icon--dark { display: none; }
	html.dark .toggle-icon--light { display: none; }
	html.dark .toggle-icon--dark  { display: inline; }


	/* NAVIGATION */
	.site-nav {
		position: sticky;
		top: 0;
		z-index: 1000;
		background: color-mix(in srgb, var(--bg-card) 88%, transparent);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
	}

	.nav__inner {
		display: flex;
		align-items: center;
		gap: 1rem;
		max-width: 1440px;
		margin: 0 auto;
		padding: 0 1.5rem;
		height: 64px;
	}

	.nav__brand {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		text-decoration: none;
		color: var(--text);
		font-family: "Playfair Display", serif;
		font-size: 1.15rem;
		font-weight: 600;
		white-space: nowrap;
		flex-shrink: 0;
	}

	.nav__brand-icon {
		width: 26px;
		height: 26px;
		display: block;
	}

	.nav__links {
		display: flex;
		align-items: center;
		gap: 0.25rem;
		list-style: none;
		margin-left: auto;
		padding: 0;
		order: 1;
	}

	.nav__link {
		display: inline-flex;
		align-items: center;
		padding: 0.5rem 0.75rem;
		min-height: 44px;
		text-decoration: none;
		color: var(--text-muted);
		font-size: 0.9rem;
		font-weight: 500;
		border-radius: 8px;
		transition: color 0.2s, background 0.2s;
		white-space: nowrap;
	}
	.nav__link:hover { color: var(--text); background: var(--bg-soft); }

	.nav__link--cta {
		background: var(--accent);
		color: #fff !important;
		padding: 0.5rem 1rem;
		border-radius: 999px;
		font-weight: 600;
	}
	.nav__link--cta:hover { background: var(--accent-dark); }

	.nav-toggle-input { display: none; }

	.nav-hamburger {
		display: none;
		flex-direction: column;
		justify-content: center;
		gap: 5px;
		cursor: pointer;
		padding: 0.5rem;
		margin-left: auto;
		min-width: 44px; min-height: 44px;
		align-items: center;
		border-radius: 8px;
		transition: background 0.2s;
	}
	.nav-hamburger:hover { background: var(--bg-soft); }

	.nav-hamburger__bar {
		display: block;
		width: 22px; height: 2px;
		background: var(--text);
		border-radius: 2px;
		transition: transform 0.3s, opacity 0.3s;
	}

	.nav-toggle-input:checked + .nav__actions .nav-hamburger__bar:nth-child(1) {
		transform: translateY(7px) rotate(45deg);
	}
	.nav-toggle-input:checked + .nav__actions .nav-hamburger__bar:nth-child(2) {
		opacity: 0;
	}
	.nav-toggle-input:checked + .nav__actions .nav-hamburger__bar:nth-child(3) {
		transform: translateY(-7px) rotate(-45deg);
	}

	@media (max-width: 767px) {
		.nav__links {
			position: fixed;
			top: 64px; left: 0; right: 0;
			background: var(--bg-card);
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			border-bottom: 1px solid var(--border);
			flex-direction: column;
			padding: 1rem;
			gap: 0.25rem;
			margin: 0;
			max-height: 0;
			overflow: hidden;
			opacity: 0;
			pointer-events: none;
			transition: max-height 0.3s ease, opacity 0.25s ease;
		}
		.nav-toggle-input:checked ~ .nav__links {
			max-height: 400px;
			opacity: 1;
			pointer-events: auto;
		}
		.nav-hamburger {
			display: flex;
		}
		.nav__actions { gap: 0.4rem; margin-left: auto; }
		.nav__link {
			width: 100%;
			padding: 0.75rem 1rem;
			font-size: 1rem;
			border-radius: 10px;
		}
		.nav__link--cta { margin-top: 0.5rem; justify-content: center; }
	}

</style>
