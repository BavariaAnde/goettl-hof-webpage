---
interface Props {
	isHome?: boolean;
}
const { isHome = false } = Astro.props as Props;
const prefix = isHome ? "" : "/";
const sectionHref = (id: string) => `${prefix}#${id}`;
const pathname = Astro.url.pathname;
const isBlogPage = pathname === "/blog/" || pathname.startsWith("/blog/");
---
<nav class="site-nav" aria-label="Hauptnavigation">
	<div class="nav__inner">
		<a class="nav__brand" href={sectionHref("hof-top")} aria-label="Göttl Hof – zurück zum Seitenanfang">
			<img src="/favicon.svg" class="nav__brand-icon" width="28" height="28" alt="" aria-hidden="true" />
			<span class="nav__brand-name">Göttl Hof</span>
		</a>

		<input type="checkbox" id="nav-toggle" class="nav-toggle-input" aria-hidden="true" />
		<div class="nav__actions">
			<button id="darkToggle" class="nav__dark-toggle" aria-label="Dark Mode umschalten" title="Dark Mode umschalten">
				<span class="toggle-icon toggle-icon--light">🌙</span>
				<span class="toggle-icon toggle-icon--dark">☀️</span>
			</button>
			<label for="nav-toggle" class="nav-hamburger" aria-label="Navigation öffnen/schließen">
				<span class="nav-hamburger__bar"></span>
				<span class="nav-hamburger__bar"></span>
				<span class="nav-hamburger__bar"></span>
			</label>
		</div>

	<ul class="nav__links" role="list">
			<li><a href={sectionHref("hof")} class="nav__link">Hof &amp; Technik</a></li>
			<li><a href={sectionHref("ausbildung")} class="nav__link">Ausbildung</a></li>
			<li><a href="/blog/" class={`nav__link${isBlogPage ? " nav__link--active" : ""}`} aria-current={isBlogPage ? "page" : undefined}>Blog</a></li>
			<li><a href={sectionHref("anfahrt")} class="nav__link">Anfahrt</a></li>
			<li><a href={sectionHref("contact")} class="nav__link nav__link--cta">Kontakt</a></li>
		</ul>
	</div>
</nav>

<script is:inline>
	(() => {
		const toggle = document.getElementById('nav-toggle');
		if (!(toggle instanceof HTMLInputElement)) return;

		document.querySelectorAll('.nav__links a').forEach((link) => {
			link.addEventListener('click', () => {
				toggle.checked = false;
			});
		});

		window.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') toggle.checked = false;
		});
	})();
</script>

<style>
.site-nav {
	position: sticky;
	top: 0;
	z-index: 1000;
	background: color-mix(in srgb, var(--bg-card) 88%, transparent);
	backdrop-filter: blur(12px);
	-webkit-backdrop-filter: blur(12px);
	border-bottom: 1px solid var(--border);
}

.nav__inner {
	display: flex;
	align-items: center;
	gap: 1rem;
	max-width: 1440px;
	margin: 0 auto;
	padding: 0 1.5rem;
	height: 64px;
}

.nav__brand {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	text-decoration: none;
	color: var(--text);
	font-family: "Playfair Display", serif;
	font-size: 1.15rem;
	font-weight: 600;
	white-space: nowrap;
	flex-shrink: 0;
}

.nav__brand-icon {
	width: 26px;
	height: 26px;
	display: block;
}

.nav__actions {
	display: flex;
	align-items: center;
	gap: 0.5rem;
	order: 2;
}

.nav__dark-toggle {
	border: 1px solid var(--border);
	background: transparent;
	border-radius: 999px;
	padding: 0.35rem 0.75rem;
	min-height: 36px;
	font-size: 0.95rem;
	line-height: 1;
	color: var(--text);
	display: inline-flex;
	align-items: center;
	gap: 0.3rem;
	cursor: pointer;
	transition: background 0.2s, color 0.2s;
}

.nav__dark-toggle:hover { background: var(--bg-soft); }

.nav__links {
	display: flex;
	align-items: center;
	gap: 0.25rem;
	list-style: none;
	margin: 0 0 0 auto;
	padding: 0;
	order: 1;
}

.nav__link {
	display: inline-flex;
	align-items: center;
	padding: 0.5rem 0.75rem;
	min-height: 44px;
	text-decoration: none;
	color: var(--text-muted);
	font-size: 0.9rem;
	font-weight: 500;
	border-radius: 8px;
	transition: color 0.2s, background 0.2s;
	white-space: nowrap;
}
.nav__link:hover { color: var(--text); background: var(--bg-soft); }

.nav__link--active {
	color: var(--text);
	background: var(--bg-soft);
}

.nav__link--cta {
	background: var(--accent);
	color: #fff !important;
	padding: 0.5rem 1rem;
	border-radius: 999px;
	font-weight: 600;
}
.nav__link--cta:hover { background: var(--accent-dark); }

.nav-toggle-input { display: none; }

.nav-hamburger {
	display: none;
	flex-direction: column;
	justify-content: center;
	gap: 5px;
	cursor: pointer;
	padding: 0.5rem;
	min-width: 44px; min-height: 44px;
	align-items: center;
	border-radius: 8px;
	transition: background 0.2s;
}
.nav-hamburger:hover { background: var(--bg-soft); }

.nav-hamburger__bar {
	display: block;
	width: 22px; height: 2px;
	background: var(--text);
	border-radius: 2px;
	transition: transform 0.3s, opacity 0.3s;
}

.nav-toggle-input:checked + .nav__actions .nav-hamburger__bar:nth-child(1) {
	transform: translateY(7px) rotate(45deg);
}
.nav-toggle-input:checked + .nav__actions .nav-hamburger__bar:nth-child(2) {
	opacity: 0;
}
.nav-toggle-input:checked + .nav__actions .nav-hamburger__bar:nth-child(3) {
	transform: translateY(-7px) rotate(-45deg);
}

@media (max-width: 767px) {
	.nav__links {
		position: fixed;
		top: 64px; left: 0; right: 0;
		background: var(--bg-card);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-bottom: 1px solid var(--border);
		flex-direction: column;
		padding: 1rem;
		gap: 0.25rem;
		margin: 0;
		max-height: 0;
		overflow: hidden;
		opacity: 0;
		pointer-events: none;
		transition: max-height 0.3s ease, opacity 0.25s ease;
	}
	.nav-toggle-input:checked ~ .nav__links {
		max-height: 400px;
		opacity: 1;
		pointer-events: auto;
	}
	.nav-hamburger { display: flex; }
	.nav__actions { gap: 0.4rem; margin-left: auto; }
	.nav__link {
		width: 100%;
		padding: 0.75rem 1rem;
		font-size: 1rem;
		border-radius: 10px;
	}
	.nav__link--active {
		background: var(--bg-strong);
	}
	.nav__link--cta { margin-top: 0.5rem; justify-content: center; }
}
</style>
