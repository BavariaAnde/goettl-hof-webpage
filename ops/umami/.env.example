# Kopiere diese Datei als .env und fülle die Werte aus.
# .env wird NICHT ins Repo committed.

# Datenbank-Passwort (frei wählbar, z.B. openssl rand -hex 24)
POSTGRES_PASSWORD=aendere_mich

# Zufälliger App-Secret (z.B. openssl rand -hex 32)
APP_SECRET=aendere_mich_ebenfalls

# Cloudflare Tunnel Token (aus dem Cloudflare Zero Trust Dashboard)
CF_TUNNEL_TOKEN=dein_cf_tunnel_token_hier

# Header, aus dem Umami die echte Besucher-IP lesen soll (Cloudflare → CF-Connecting-IP)
CLIENT_IP_HEADER=CF-Connecting-IP
